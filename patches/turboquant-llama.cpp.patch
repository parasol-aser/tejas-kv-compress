diff --git a/ggml/src/ggml-common.h b/ggml/src/ggml-common.h
index f05683b44..6feb5e978 100644
--- a/ggml/src/ggml-common.h
+++ b/ggml/src/ggml-common.h
@@ -277,6 +277,34 @@ typedef struct {
 } block_tq2_0;
 static_assert(sizeof(block_tq2_0) == sizeof(ggml_half) + QK_K / 4, "wrong tq2_0 block size/padding");
 
+//
+// TurboQuant (arxiv 2504.19874): random rotation + Lloyd-Max codebook on the
+// rotated coordinates. Block size == head dim. 4-bit variant only, d=128.
+//
+#define QK_TQ_MSE_4 128
+typedef struct {
+    ggml_half d;                   // norm scale = ||x||
+    uint8_t   qs[QK_TQ_MSE_4 / 2]; // 4-bit codebook indices, two per byte
+} block_tq_mse_4;
+static_assert(sizeof(block_tq_mse_4) == sizeof(ggml_half) + QK_TQ_MSE_4 / 2, "wrong tq_mse_4 block size/padding");
+
+// TurboQuant (Algorithm 2 / Prod variant): MSE-4 stage + 1-bit JL sign sketch
+// of the per-block residual, with a separate fp16 scale gamma = ||r||.
+// Sketch is performed in the rotated coordinate basis (a fresh iid Gaussian
+// matrix M plays the role of S * Pi^T from the prototype's unit-space sketch).
+//
+// Layout per 128 elements:
+//   d     (2B) + gamma (2B) + qs (64B, 4-bit MSE indices) + qjl (16B, 1-bit signs)
+//   = 84B = 5.25 bpv
+#define QK_TQ_PROD_4 128
+typedef struct {
+    ggml_half d;                       // norm scale = ||x||
+    ggml_half gamma;                   // residual norm = ||r_rot||
+    uint8_t   qs [QK_TQ_PROD_4 / 2];   // MSE 4-bit indices, two per byte
+    uint8_t   qjl[QK_TQ_PROD_4 / 8];   // JL sign bits (LSB-first within each byte)
+} block_tq_prod_4;
+static_assert(sizeof(block_tq_prod_4) == 2 * sizeof(ggml_half) + QK_TQ_PROD_4 / 2 + QK_TQ_PROD_4 / 8, "wrong tq_prod_4 block size/padding");
+
 //
 // Super-block quantization structures
 //
