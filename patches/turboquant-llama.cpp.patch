+// ---------------------------------------------------------------------------
+// TurboQuant (MSE variant, 4-bit, head dim 128)
+// Paper: "TurboQuant: Online vector quantization with coding complexity
+// guarantees" (arXiv:2504.19874). Algorithm 1.
+//
+// - Pick a fixed random orthogonal rotation Pi (128x128) at startup.
+// - Per block: y = Pi @ (x / ||x||). Round each y[j] to the nearest of 16
+//   centroids chosen by Lloyd-Max on a standard Gaussian (valid asymptotic
+//   distribution of rotated unit-sphere coords for large d).
+// - Store ||x|| as fp16 scale and the 16-level code indices packed 2 per byte.
+// ---------------------------------------------------------------------------
+
+#ifndef M_PI
+#define M_PI 3.14159265358979323846
+#endif
+
+#define TQ_MSE_4_DIM  QK_TQ_MSE_4
+#define TQ_MSE_4_K    16
+#define TQ_MSE_4_SEED 42ULL
+
+// 0 = uninitialized, 1 = someone is initializing, 2 = tables ready.
+// Atomics give us a lockless, recursion-safe one-shot init; whoever wins
+// the 0->1 CAS builds the tables, others spin until the state reaches 2.
+static atomic_int g_tq_mse_4_state = 0;
+static float      g_tq_mse_4_Pi  [TQ_MSE_4_DIM * TQ_MSE_4_DIM]; // Pi  [i*d + j]
+static float      g_tq_mse_4_PiT [TQ_MSE_4_DIM * TQ_MSE_4_DIM]; // PiT [i*d + j] = Pi[j*d + i]
+static float      g_tq_mse_4_codebook[TQ_MSE_4_K];
+
+// xoshiro256** + splitmix64 seeding — deterministic across platforms.
+static uint64_t g_tq_rng[4];
+
+static inline uint64_t tq_rotl(uint64_t x, int k) {
+    return (x << k) | (x >> (64 - k));
+}
+
+static uint64_t tq_next_u64(void) {
+    const uint64_t result = tq_rotl(g_tq_rng[1] * 5, 7) * 9;
+    const uint64_t t = g_tq_rng[1] << 17;
+    g_tq_rng[2] ^= g_tq_rng[0];
+    g_tq_rng[3] ^= g_tq_rng[1];
+    g_tq_rng[1] ^= g_tq_rng[2];
+    g_tq_rng[0] ^= g_tq_rng[3];
+    g_tq_rng[2] ^= t;
+    g_tq_rng[3] = tq_rotl(g_tq_rng[3], 45);
+    return result;
+}
+
+static void tq_seed(uint64_t seed) {
+    uint64_t x = seed;
+    for (int i = 0; i < 4; ++i) {
+        x += 0x9E3779B97F4A7C15ULL;
+        uint64_t z = x;
+        z = (z ^ (z >> 30)) * 0xBF58476D1CE4E5B9ULL;
+        z = (z ^ (z >> 27)) * 0x94D049BB133111EBULL;
+        z =  z ^ (z >> 31);
+        g_tq_rng[i] = z;
+    }
+}
+
+static double tq_next_u01(void) {
+    // 53 random bits -> [0, 1)
+    return (tq_next_u64() >> 11) * (1.0 / (double)(1ULL << 53));
+}
+
+static float tq_next_gauss(void) {
+    double u1 = tq_next_u01();
+    double u2 = tq_next_u01();
+    if (u1 < 1e-300) u1 = 1e-300;
+    double r = sqrt(-2.0 * log(u1));
+    return (float)(r * cos(2.0 * M_PI * u2));
+}
+
+// In-place modified Gram-Schmidt orthonormalization of the d rows of A (row-major).
+static void tq_modified_gram_schmidt(float * A, int d) {
+    for (int i = 0; i < d; ++i) {
+        float * ri = A + (size_t)i * d;
+        for (int j = 0; j < i; ++j) {
+            const float * rj = A + (size_t)j * d;
+            float dot = 0.0f;
+            for (int k = 0; k < d; ++k) dot += ri[k] * rj[k];
+            for (int k = 0; k < d; ++k) ri[k] -= dot * rj[k];
+        }
+        float norm2 = 0.0f;
+        for (int k = 0; k < d; ++k) norm2 += ri[k] * ri[k];
+        float norm = sqrtf(norm2);
+        if (norm < 1e-20f) norm = 1.0f;
+        const float inv = 1.0f / norm;
+        for (int k = 0; k < d; ++k) ri[k] *= inv;
+    }
+}
+
+// Fills the tables. Called by exactly one thread (the CAS winner).
+static void tq_mse_4_build_tables(void) {
+    const int d = TQ_MSE_4_DIM;
+
+    // 1. Fill Pi with Gaussian entries, then orthonormalize its rows.
+    tq_seed(TQ_MSE_4_SEED);
+    for (int i = 0; i < d * d; ++i) {
+        g_tq_mse_4_Pi[i] = tq_next_gauss();
+    }
+    tq_modified_gram_schmidt(g_tq_mse_4_Pi, d);
+
+    // 2. Transpose for fast inverse rotation during dequant.
+    for (int i = 0; i < d; ++i) {
+        for (int j = 0; j < d; ++j) {
+            g_tq_mse_4_PiT[(size_t)i * d + j] = g_tq_mse_4_Pi[(size_t)j * d + i];
+        }
+    }
+
+    // 3. Lloyd-Max 16-level centroids for standard normal N(0,1), scaled by
+    //    sigma = 1/sqrt(d) (asymptotic marginal of rotated unit sphere).
+    //    Reference values (Lloyd 1982, N=16; symmetric, mean-zero).
+    static const float centroids_stdnormal[TQ_MSE_4_K] = {
+        -2.7326f, -2.0690f, -1.6180f, -1.2562f,
+        -0.9423f, -0.6568f, -0.3881f, -0.1284f,
+         0.1284f,  0.3881f,  0.6568f,  0.9423f,
+         1.2562f,  1.6180f,  2.0690f,  2.7326f
+    };
+    const float sigma = 1.0f / sqrtf((float)d);
+    for (int i = 0; i < TQ_MSE_4_K; ++i) {
+        g_tq_mse_4_codebook[i] = centroids_stdnormal[i] * sigma;
+    }
+}
+
+// Accessors for other backends (e.g. the CUDA port) to pull the host-side
+// tables directly. Safe to call from any thread; the caller must already
+// have triggered init via tq_mse_4_init_impl() (or accept the first call
+// here does it for them).
+const float * ggml_tq_mse_4_host_pi(void) {
+    tq_mse_4_init_impl();
+    return g_tq_mse_4_Pi;
+}
+
+const float * ggml_tq_mse_4_host_piT(void) {
+    tq_mse_4_init_impl();
+    return g_tq_mse_4_PiT;
+}
+
+const float * ggml_tq_mse_4_host_codebook(void) {
+    tq_mse_4_init_impl();
+    return g_tq_mse_4_codebook;
+}
+
+void tq_mse_4_init_impl(void) {
+    // Fast path: tables already published.
+    if (atomic_load_explicit(&g_tq_mse_4_state, memory_order_acquire) == 2) return;
+
+    // Try to become the initializer.
+    int expected = 0;
+    if (atomic_compare_exchange_strong_explicit(
+            &g_tq_mse_4_state, &expected, 1,
+            memory_order_acq_rel, memory_order_acquire)) {
+        tq_mse_4_build_tables();
+        atomic_store_explicit(&g_tq_mse_4_state, 2, memory_order_release);
+        return;
+    }
+
+    // Somebody else is (or was) initializing. Spin until ready.
+    while (atomic_load_explicit(&g_tq_mse_4_state, memory_order_acquire) != 2) {
+        // Tables are small and init is fast; a plain busy loop is fine here.
+    }
+}
+
+// Find nearest codebook index. The codebook is sorted ascending, so a linear
+// scan with early-exit on monotone |diff| works, but a simple scan is clearer
+// for 16 entries.
+static inline uint8_t tq_nearest_idx(float v) {
+    float best = fabsf(v - g_tq_mse_4_codebook[0]);
+    uint8_t bi = 0;
+    for (uint8_t i = 1; i < TQ_MSE_4_K; ++i) {
+        float d = fabsf(v - g_tq_mse_4_codebook[i]);
+        if (d < best) { best = d; bi = i; }
+    }
+    return bi;
+}
+
+void quantize_row_tq_mse_4_ref(const float * GGML_RESTRICT x, block_tq_mse_4 * GGML_RESTRICT y, int64_t k) {
+    tq_mse_4_init_impl();
+    assert(k % TQ_MSE_4_DIM == 0);
+    const int nb = (int)(k / TQ_MSE_4_DIM);
+    const int d  = TQ_MSE_4_DIM;
+
+    for (int b = 0; b < nb; ++b) {
+        const float * xb = x + (size_t)b * d;
+
+        // Scale = ||x|| (fp16). For all-zero blocks we emit zero indices.
+        float sumsq = 0.0f;
+        for (int i = 0; i < d; ++i) sumsq += xb[i] * xb[i];
+        const float norm = sqrtf(sumsq);
+        y[b].d = GGML_FP32_TO_FP16(norm);
+
+        if (norm < 1e-20f) {
+            // Pick an index whose centroid is closest to 0. Codebook is
+            // symmetric so index K/2-1 or K/2 both map to the same |error|.
+            const uint8_t zi = TQ_MSE_4_K / 2 - 1;
+            for (int i = 0; i < d / 2; ++i) {
+                y[b].qs[i] = (uint8_t)(zi | (zi << 4));
+            }
+            continue;
+        }
+
+        const float inv_norm = 1.0f / norm;
+
+        // y_rot[i] = sum_j Pi[i*d + j] * (x[j] / norm)
+        for (int i = 0; i < d; i += 2) {
+            const float * pi_row_0 = g_tq_mse_4_Pi + (size_t)(i    ) * d;
+            const float * pi_row_1 = g_tq_mse_4_Pi + (size_t)(i + 1) * d;
+            float y0 = 0.0f, y1 = 0.0f;
+            for (int j = 0; j < d; ++j) {
+                const float xj = xb[j] * inv_norm;
+                y0 += pi_row_0[j] * xj;
+                y1 += pi_row_1[j] * xj;
+            }
+            const uint8_t i0 = tq_nearest_idx(y0);
+            const uint8_t i1 = tq_nearest_idx(y1);
+            y[b].qs[i >> 1] = (uint8_t)(i0 | (i1 << 4));
+        }
+    }
+}
+
+void dequantize_row_tq_mse_4(const block_tq_mse_4 * GGML_RESTRICT x, float * GGML_RESTRICT y, int64_t k) {
+    tq_mse_4_init_impl();
+    assert(k % TQ_MSE_4_DIM == 0);
+    const int nb = (int)(k / TQ_MSE_4_DIM);
+    const int d  = TQ_MSE_4_DIM;
+
+    float y_rot[TQ_MSE_4_DIM];
+
+    for (int b = 0; b < nb; ++b) {
+        const float scale = GGML_FP16_TO_FP32(x[b].d);
+
+        for (int i = 0; i < d; i += 2) {
+            const uint8_t byte = x[b].qs[i >> 1];
+            y_rot[i    ] = g_tq_mse_4_codebook[byte & 0x0F];
+            y_rot[i + 1] = g_tq_mse_4_codebook[byte >>   4];
+        }
+
+        // x_hat = scale * Pi^T @ y_rot
+        float * yb = y + (size_t)b * d;
+        for (int i = 0; i < d; ++i) {
+            const float * pit_row = g_tq_mse_4_PiT + (size_t)i * d;
+            float s = 0.0f;
+            for (int j = 0; j < d; ++j) {
+                s += pit_row[j] * y_rot[j];
+            }
+            yb[i] = scale * s;
+        }
+    }
+}
+
+// ---------------------------------------------------------------------------
+// TurboQuant Prod (Algorithm 2): MSE-4 + 1-bit JL sign sketch of the residual.
+//
+// Reuses the MSE tables (Pi, Pi^T, 16-level Lloyd-Max codebook). Adds an
+// independent dxd Gaussian sketch matrix M and its transpose M^T, with a
+// distinct PRNG seed so M is statistically independent of Pi.
+//
+// Sketch is performed in *rotated* space: r_rot = Pi @ x_unit - codebook[idx].
+// Storing qjl = sign(M @ r_rot) and gamma = ||r_rot|| lets the decoder form
+// y_jl_rot = (sqrt(pi/2)/d) * gamma * M^T @ qjl_signed and reconstruct
+// x_hat = ||x|| * Pi^T @ (codebook[idx] + y_jl_rot). E[y_jl_rot] = r_rot,
+// so the inner-product estimate is unbiased (within fp16 / quantization noise).
+// ---------------------------------------------------------------------------
+
+#define TQ_PROD_4_DIM   QK_TQ_PROD_4
+#define TQ_PROD_4_SEED  43ULL
+
+static atomic_int g_tq_prod_4_state = 0;
+static float      g_tq_prod_4_M [TQ_PROD_4_DIM * TQ_PROD_4_DIM]; // M  [i*d + j]
+static float      g_tq_prod_4_MT[TQ_PROD_4_DIM * TQ_PROD_4_DIM]; // M^T
+
+static void tq_prod_4_build_tables(void) {
+    const int d = TQ_PROD_4_DIM;
+
+    // M = iid N(0,1) Gaussian. NOT orthonormalized — Algorithm 2 wants a
+    // plain Gaussian sketch, not a rotation.
+    tq_seed(TQ_PROD_4_SEED);
+    for (int i = 0; i < d * d; ++i) {
+        g_tq_prod_4_M[i] = tq_next_gauss();
+    }
+
+    // Transpose for the dequant path.
+    for (int i = 0; i < d; ++i) {
+        for (int j = 0; j < d; ++j) {
+            g_tq_prod_4_MT[(size_t)i * d + j] = g_tq_prod_4_M[(size_t)j * d + i];
+        }
+    }
+}
+
+void tq_prod_4_init_impl(void) {
+    // We need the MSE tables (Pi, Pi^T, codebook) for the first stage.
+    tq_mse_4_init_impl();
+
+    if (atomic_load_explicit(&g_tq_prod_4_state, memory_order_acquire) == 2) return;
+
+    int expected = 0;
+    if (atomic_compare_exchange_strong_explicit(
+            &g_tq_prod_4_state, &expected, 1,
+            memory_order_acq_rel, memory_order_acquire)) {
+        tq_prod_4_build_tables();
+        atomic_store_explicit(&g_tq_prod_4_state, 2, memory_order_release);
+        return;
+    }
+
+    while (atomic_load_explicit(&g_tq_prod_4_state, memory_order_acquire) != 2) {
+    }
+}
+
+const float * ggml_tq_prod_4_host_M(void) {
+    tq_prod_4_init_impl();
+    return g_tq_prod_4_M;
+}
+
+const float * ggml_tq_prod_4_host_MT(void) {
+    tq_prod_4_init_impl();
+    return g_tq_prod_4_MT;
+}
+
+void quantize_row_tq_prod_4_ref(const float * GGML_RESTRICT x, block_tq_prod_4 * GGML_RESTRICT y, int64_t k) {
+    tq_prod_4_init_impl();
+    assert(k % TQ_PROD_4_DIM == 0);
+    const int nb = (int)(k / TQ_PROD_4_DIM);
+    const int d  = TQ_PROD_4_DIM;
+
+    float y_rot[TQ_PROD_4_DIM];
+    float r_rot[TQ_PROD_4_DIM];
+
+    for (int b = 0; b < nb; ++b) {
+        const float * xb = x + (size_t)b * d;
+
+        float sumsq = 0.0f;
+        for (int i = 0; i < d; ++i) sumsq += xb[i] * xb[i];
+        const float norm = sqrtf(sumsq);
+        y[b].d = GGML_FP32_TO_FP16(norm);
+
+        if (norm < 1e-20f) {
+            // Zero block: pick the middle codebook index (closest to 0) and
+            // zero out the JL sketch.
+            const uint8_t zi = TQ_MSE_4_K / 2 - 1;
+            for (int i = 0; i < d / 2; ++i) {
+                y[b].qs[i] = (uint8_t)(zi | (zi << 4));
+            }
+            for (int i = 0; i < d / 8; ++i) y[b].qjl[i] = 0;
+            y[b].gamma = GGML_FP32_TO_FP16(0.0f);
+            continue;
+        }
+
+        const float inv_norm = 1.0f / norm;
+
+        // Stage 1: y_rot = Pi @ (x / norm), pick codebook indices, residual.
+        for (int i = 0; i < d; ++i) {
+            const float * pi_row = g_tq_mse_4_Pi + (size_t)i * d;
+            float yi = 0.0f;
+            for (int j = 0; j < d; ++j) {
+                yi += pi_row[j] * (xb[j] * inv_norm);
+            }
+            y_rot[i] = yi;
+        }
+
+        for (int i = 0; i < d; i += 2) {
+            const uint8_t i0 = tq_nearest_idx(y_rot[i    ]);
+            const uint8_t i1 = tq_nearest_idx(y_rot[i + 1]);
+            y[b].qs[i >> 1] = (uint8_t)(i0 | (i1 << 4));
+            r_rot[i    ] = y_rot[i    ] - g_tq_mse_4_codebook[i0];
+            r_rot[i + 1] = y_rot[i + 1] - g_tq_mse_4_codebook[i1];
+        }
+
+        // gamma = ||r_rot|| (== ||r_unit|| since Pi is orthogonal).
+        float r_sumsq = 0.0f;
+        for (int i = 0; i < d; ++i) r_sumsq += r_rot[i] * r_rot[i];
+        y[b].gamma = GGML_FP32_TO_FP16(sqrtf(r_sumsq));
+
+        // Stage 2: qjl = sign(M @ r_rot). Bit i of byte i/8 = (sign >= 0).
+        // Pack LSB-first; tie-breaks (sr == 0) emit +1 to match the prototype.
+        for (int i = 0; i < d / 8; ++i) y[b].qjl[i] = 0;
+        for (int i = 0; i < d; ++i) {
+            const float * m_row = g_tq_prod_4_M + (size_t)i * d;
+            float sr = 0.0f;
+            for (int j = 0; j < d; ++j) sr += m_row[j] * r_rot[j];
+            const uint8_t bit = (sr >= 0.0f) ? 1u : 0u;
+            y[b].qjl[i >> 3] |= (uint8_t)(bit << (i & 7));
+        }
+    }
+}
+
+void dequantize_row_tq_prod_4(const block_tq_prod_4 * GGML_RESTRICT x, float * GGML_RESTRICT y, int64_t k) {
+    tq_prod_4_init_impl();
+    assert(k % TQ_PROD_4_DIM == 0);
+    const int nb = (int)(k / TQ_PROD_4_DIM);
+    const int d  = TQ_PROD_4_DIM;
+
+    float y_full_rot[TQ_PROD_4_DIM];
+    float qjl_signed[TQ_PROD_4_DIM];
+
+    // (sqrt(pi/2)/d) * gamma is the JL inverse-sketch coefficient.
+    const float jl_coef_const = sqrtf((float)M_PI / 2.0f) / (float)d;
+
+    for (int b = 0; b < nb; ++b) {
+        const float scale = GGML_FP16_TO_FP32(x[b].d);
+        const float gamma = GGML_FP16_TO_FP32(x[b].gamma);
+        const float jl_c  = jl_coef_const * gamma;
+
+        // Decode MSE indices into rotated-space centroids.
+        for (int i = 0; i < d; i += 2) {
+            const uint8_t byte = x[b].qs[i >> 1];
+            y_full_rot[i    ] = g_tq_mse_4_codebook[byte & 0x0F];
+            y_full_rot[i + 1] = g_tq_mse_4_codebook[byte >>   4];
+        }
+
+        // Unpack JL sign bits to +/-1 floats.
+        for (int i = 0; i < d; ++i) {
+            const uint8_t bit = (x[b].qjl[i >> 3] >> (i & 7)) & 1u;
+            qjl_signed[i] = bit ? 1.0f : -1.0f;
+        }
+
+        // Add JL residual estimate in rotated space:
+        //   y_full_rot += (sqrt(pi/2)/d) * gamma * M^T @ qjl_signed
+        for (int i = 0; i < d; ++i) {
+            const float * mt_row = g_tq_prod_4_MT + (size_t)i * d;
+            float s = 0.0f;
+            for (int j = 0; j < d; ++j) s += mt_row[j] * qjl_signed[j];
+            y_full_rot[i] += jl_c * s;
+        }
+
+        // x_hat = scale * Pi^T @ y_full_rot
+        float * yb = y + (size_t)b * d;
+        for (int i = 0; i < d; ++i) {
+            const float * pit_row = g_tq_mse_4_PiT + (size_t)i * d;
+            float s = 0.0f;
+            for (int j = 0; j < d; ++j) s += pit_row[j] * y_full_rot[j];
+            yb[i] = scale * s;
+        }
+    }
+}
+
