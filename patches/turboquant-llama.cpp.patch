diff --git a/ggml/src/ggml-cpu/quants.c b/ggml/src/ggml-cpu/quants.c
index e5f9a4083..ffd37d296 100644
--- a/ggml/src/ggml-cpu/quants.c
+++ b/ggml/src/ggml-cpu/quants.c
@@ -112,6 +112,84 @@ void quantize_row_tq2_0(const float * GGML_RESTRICT x, void * GGML_RESTRICT vy,
     quantize_row_tq2_0_ref(x, y, k);
 }
 
+// TurboQuant MSE-4 (see ggml-quants.c). Quantize-from-float path on CPU: just
+// forward to the reference implementation. Tables must already be initialized
+// via ggml_quantize_init(GGML_TYPE_TQ_MSE_4).
+void quantize_row_tq_mse_4(const float * GGML_RESTRICT x, void * GGML_RESTRICT vy, int64_t k) {
+    assert(k % QK_TQ_MSE_4 == 0);
+    block_tq_mse_4 * GGML_RESTRICT y = vy;
+    quantize_row_tq_mse_4_ref(x, y, k);
+}
+
+// Dot(K, Q) where K is TQ_MSE_4 and Q is float32. Dequantize one block at a
+// time to a stack buffer and run a plain float dot.
+void ggml_vec_dot_tq_mse_4_f32(int n, float * GGML_RESTRICT s, size_t bs,
+                                const void * GGML_RESTRICT vx, size_t bx,
+                                const void * GGML_RESTRICT vy, size_t by,
+                                int nrc) {
+    assert(nrc == 1);
+    UNUSED(nrc); UNUSED(bx); UNUSED(by); UNUSED(bs);
+
+    const int qk = QK_TQ_MSE_4;
+    assert(n % qk == 0);
+    const int nb = n / qk;
+
+    const block_tq_mse_4 * GGML_RESTRICT x = vx;
+    const float          * GGML_RESTRICT y = vy;
+
+    float decoded[QK_TQ_MSE_4];
+    float sumf = 0.0f;
+
+    for (int b = 0; b < nb; ++b) {
+        dequantize_row_tq_mse_4(x + b, decoded, qk);
+        const float * yb = y + (size_t)b * qk;
+        for (int i = 0; i < qk; ++i) {
+            sumf += decoded[i] * yb[i];
+        }
+    }
+
+    *s = sumf;
+}
+
+// TurboQuant Prod-4 from-float: forward to the reference implementation.
+// Tables must already be initialized via ggml_quantize_init(GGML_TYPE_TQ_PROD_4).
+void quantize_row_tq_prod_4(const float * GGML_RESTRICT x, void * GGML_RESTRICT vy, int64_t k) {
+    assert(k % QK_TQ_PROD_4 == 0);
+    block_tq_prod_4 * GGML_RESTRICT y = vy;
+    quantize_row_tq_prod_4_ref(x, y, k);
+}
+
+// Same dequant-then-dot strategy as TQ_MSE_4. The Prod variant carries the JL
+// residual estimator inside dequantize_row_tq_prod_4, so the resulting dot is
+// the unbiased inner-product estimate (Algorithm 2).
+void ggml_vec_dot_tq_prod_4_f32(int n, float * GGML_RESTRICT s, size_t bs,
+                                 const void * GGML_RESTRICT vx, size_t bx,
+                                 const void * GGML_RESTRICT vy, size_t by,
+                                 int nrc) {
+    assert(nrc == 1);
+    UNUSED(nrc); UNUSED(bx); UNUSED(by); UNUSED(bs);
+
+    const int qk = QK_TQ_PROD_4;
+    assert(n % qk == 0);
+    const int nb = n / qk;
+
+    const block_tq_prod_4 * GGML_RESTRICT x = vx;
+    const float           * GGML_RESTRICT y = vy;
+
+    float decoded[QK_TQ_PROD_4];
+    float sumf = 0.0f;
+
+    for (int b = 0; b < nb; ++b) {
+        dequantize_row_tq_prod_4(x + b, decoded, qk);
+        const float * yb = y + (size_t)b * qk;
+        for (int i = 0; i < qk; ++i) {
+            sumf += decoded[i] * yb[i];
+        }
+    }
+
+    *s = sumf;
+}
+
