+GGML_API void tq_prod_4_init_impl(void);
+GGML_API const float * ggml_tq_prod_4_host_M(void);
+GGML_API const float * ggml_tq_prod_4_host_MT(void);
+
 #ifdef __cplusplus
 }
 #endif
