-        GGML_TYPE_COUNT   = 42,
+        GGML_TYPE_TQ_MSE_4 = 42, // TurboQuant MSE, 4-bit, head dim 128 (KV cache only)
+        GGML_TYPE_TQ_PROD_4 = 43, // TurboQuant Prod (Algorithm 2): MSE-4 + 1-bit JL sketch, head dim 128
