+++ b/tests/test-turboquant-prod-cuda.cpp
@@ -0,0 +1,197 @@
+// CPU <-> CUDA parity test for GGML_TYPE_TQ_PROD_4 (TurboQuant Algorithm 2:
+// MSE-4 + 1-bit JL sketch on the residual).
+//
+// Same structure as test-turboquant-cuda.cpp:
+//
+//   x  --cpu_quant--> q  --cpu_dequant--> x_hat_cpu_cpu
+//   x  --cpu_quant--> q  --gpu_dequant--> x_hat_cpu_gpu
+//   x  --gpu_quant--> q  --cpu_dequant--> x_hat_gpu_cpu
+//   x  --gpu_quant--> q  --gpu_dequant--> x_hat_gpu_gpu
+//
+// Both backends share Pi / codebook / M / M^T (CPU builds them; CUDA copies
+// via cudaMemcpyToSymbol), so the packed bytes should agree on >=95% of
+// blocks (rounding + 1-bit-sketch borderline cases account for the slack)
+// and the dequantized vectors should agree to a few ULPs.
+//
+// If compiled without CUDA backend, prints SKIP and exits 0.
+
+#include "ggml.h"
+#include "ggml-cpu.h"
+#include "ggml-backend.h"
+#include "ggml-alloc.h"
+
+#include <cassert>
+#include <cmath>
+#include <cstdio>
+#include <cstring>
+#include <random>
+#include <string>
+#include <vector>
+
+static float mean_sq_err(const float * a, const float * b, size_t n) {
+    double s = 0.0;
+    for (size_t i = 0; i < n; ++i) {
+        double d = (double)a[i] - (double)b[i];
+        s += d * d;
+    }
+    return (float)(s / (double)n);
+}
+
+static float max_abs_err(const float * a, const float * b, size_t n) {
+    float m = 0.0f;
+    for (size_t i = 0; i < n; ++i) {
+        float d = std::fabs(a[i] - b[i]);
+        if (d > m) m = d;
+    }
+    return m;
+}
+
+static ggml_backend_t find_cuda_backend() {
+    const size_t n = ggml_backend_reg_count();
+    for (size_t i = 0; i < n; ++i) {
+        ggml_backend_reg_t reg = ggml_backend_reg_get(i);
+        const char * name = ggml_backend_reg_name(reg);
+        if (name && std::string(name).find("CUDA") != std::string::npos) {
+            const size_t nd = ggml_backend_reg_dev_count(reg);
+            if (nd == 0) continue;
+            ggml_backend_dev_t dev = ggml_backend_reg_dev_get(reg, 0);
+            return ggml_backend_dev_init(dev, /*params=*/nullptr);
+        }
+    }
+    return nullptr;
+}
+
+template <typename T>
+static std::vector<T> run_cpy_on_backend(
+        ggml_backend_t backend,
+        const float * x_host, ggml_type src_type, ggml_type dst_type,
+        int64_t n_elements) {
+    ggml_init_params ctx_params = { /*.mem_size=*/ 16*1024*1024,
+                                     /*.mem_buffer=*/ nullptr,
+                                     /*.no_alloc=*/ true };
+    ggml_context * ctx = ggml_init(ctx_params);
+
+    ggml_tensor * src = ggml_new_tensor_1d(ctx, src_type, n_elements);
+    ggml_tensor * dst = ggml_new_tensor_1d(ctx, dst_type, n_elements);
+    ggml_set_name(src, "src");
+    ggml_set_name(dst, "dst");
+
+    ggml_cgraph * gf = ggml_new_graph(ctx);
+    ggml_tensor * cpy = ggml_cpy(ctx, src, dst);
+    ggml_build_forward_expand(gf, cpy);
+
+    ggml_backend_buffer_t buf = ggml_backend_alloc_ctx_tensors(ctx, backend);
+    GGML_ASSERT(buf != nullptr);
+
+    const size_t bytes_src = ggml_nbytes(src);
+    ggml_backend_tensor_set(src, x_host, 0, bytes_src);
+
+    ggml_backend_graph_compute(backend, gf);
+
+    const size_t bytes_dst = ggml_nbytes(dst);
+    std::vector<T> out(bytes_dst / sizeof(T));
+    ggml_backend_tensor_get(dst, out.data(), 0, bytes_dst);
+
+    ggml_backend_buffer_free(buf);
+    ggml_free(ctx);
+    return out;
+}
+
+int main() {
+    ggml_backend_load_all();
+    ggml_cpu_init();
+
+    ggml_backend_t cpu = ggml_backend_cpu_init();
+    ggml_backend_t gpu = find_cuda_backend();
+
+    if (!gpu) {
+        printf("[test-turboquant-prod-cuda] SKIP: no CUDA backend available.\n");
+        ggml_backend_free(cpu);
+        return 0;
+    }
+
+    // Touch the CPU tables before the GPU pulls them.
+    ggml_quantize_init(GGML_TYPE_TQ_PROD_4);
+
+    const int64_t N_BLOCKS = 8;
+    const int64_t n        = N_BLOCKS * 128;
+
+    std::mt19937 rng(19);
+    std::normal_distribution<float> gauss(0.0f, 1.0f);
+
+    std::vector<float> x(n);
+    for (int64_t i = 0; i < n; ++i) x[i] = gauss(rng);
+
+    // ---- 1. quant on each backend, compare packed bytes --------------------
+    auto q_cpu = run_cpy_on_backend<uint8_t>(cpu, x.data(), GGML_TYPE_F32, GGML_TYPE_TQ_PROD_4, n);
+    auto q_gpu = run_cpy_on_backend<uint8_t>(gpu, x.data(), GGML_TYPE_F32, GGML_TYPE_TQ_PROD_4, n);
+
+    assert(q_cpu.size() == q_gpu.size());
+    int byte_diffs = 0;
+    for (size_t i = 0; i < q_cpu.size(); ++i) {
+        if (q_cpu[i] != q_gpu[i]) ++byte_diffs;
+    }
+    printf("[test-turboquant-prod-cuda] packed-bytes: %d/%zu differ between CPU and GPU quant\n",
+           byte_diffs, q_cpu.size());
+
+    // 5% slack for the MSE-stage rounding and JL-sketch sign borderline cases.
+    if (byte_diffs > (int)(q_cpu.size() / 20)) {
+        printf("FAIL: too many packed-byte mismatches (> 5%%)\n");
+        return 1;
+    }
+
+    // ---- 2. dequant(cpu_q) on each backend ---------------------------------
+    auto deq_cpu_from_cpu = run_cpy_on_backend<float>(cpu, (const float *)q_cpu.data(), GGML_TYPE_TQ_PROD_4, GGML_TYPE_F32, n);
+    auto deq_gpu_from_cpu = run_cpy_on_backend<float>(gpu, (const float *)q_cpu.data(), GGML_TYPE_TQ_PROD_4, GGML_TYPE_F32, n);
+
+    const float tol_mse = 1e-5f;
+    const float tol_max = 5e-3f;
+
+    const float mse_cc_gc = mean_sq_err(deq_cpu_from_cpu.data(), deq_gpu_from_cpu.data(), n);
+    const float mxe_cc_gc = max_abs_err(deq_cpu_from_cpu.data(), deq_gpu_from_cpu.data(), n);
+    printf("[test-turboquant-prod-cuda] dequant parity (cpu_q -> cpu vs gpu): mse=%.2e max_abs=%.2e\n",
+           mse_cc_gc, mxe_cc_gc);
+    if (!(mse_cc_gc < tol_mse && mxe_cc_gc < tol_max)) {
+        printf("FAIL: dequant(cpu_q) diverges between backends\n");
+        return 1;
+    }
+
+    // ---- 3. dequant(gpu_q) on each backend ---------------------------------
+    auto deq_cpu_from_gpu = run_cpy_on_backend<float>(cpu, (const float *)q_gpu.data(), GGML_TYPE_TQ_PROD_4, GGML_TYPE_F32, n);
+    auto deq_gpu_from_gpu = run_cpy_on_backend<float>(gpu, (const float *)q_gpu.data(), GGML_TYPE_TQ_PROD_4, GGML_TYPE_F32, n);
+
+    const float mse_cg_gg = mean_sq_err(deq_cpu_from_gpu.data(), deq_gpu_from_gpu.data(), n);
+    const float mxe_cg_gg = max_abs_err(deq_cpu_from_gpu.data(), deq_gpu_from_gpu.data(), n);
+    printf("[test-turboquant-prod-cuda] dequant parity (gpu_q -> cpu vs gpu): mse=%.2e max_abs=%.2e\n",
+           mse_cg_gg, mxe_cg_gg);
+    if (!(mse_cg_gg < tol_mse && mxe_cg_gg < tol_max)) {
+        printf("FAIL: dequant(gpu_q) diverges between backends\n");
+        return 1;
+    }
+
+    // ---- 4. full round-trip error on GPU -----------------------------------
+    std::vector<float> x_unit = x;
+    for (int64_t b = 0; b < N_BLOCKS; ++b) {
+        double s = 0;
+        for (int i = 0; i < 128; ++i) s += (double)x_unit[b*128+i] * x_unit[b*128+i];
+        s = std::sqrt(s);
+        if (s > 0) for (int i = 0; i < 128; ++i) x_unit[b*128+i] /= (float)s;
+    }
+    auto qu_gpu = run_cpy_on_backend<uint8_t>(gpu, x_unit.data(), GGML_TYPE_F32, GGML_TYPE_TQ_PROD_4, n);
+    auto xh_gpu = run_cpy_on_backend<float>(gpu, (const float *)qu_gpu.data(), GGML_TYPE_TQ_PROD_4, GGML_TYPE_F32, n);
+    const float rt_mse = mean_sq_err(x_unit.data(), xh_gpu.data(), n);
+    printf("[test-turboquant-prod-cuda] unit-norm GPU round-trip MSE: %.5f (CPU baseline ~1e-4)\n",
+           rt_mse);
+    // Prod-4's reconstruction has higher per-element MSE than MSE-4 (the JL
+    // stage trades bias for variance), so allow a looser bound.
+    if (!(rt_mse < 1e-2f)) {
+        printf("FAIL: round-trip MSE too high\n");
+        return 1;
+    }
+
+    printf("[test-turboquant-prod-cuda] OK\n");
+
+    ggml_backend_free(gpu);
+    ggml_backend_free(cpu);
+    return 0;
+}
diff --git a/tests/test-turboquant-prod.cpp b/tests/test-turboquant-prod.cpp
new file mode 100644
index 000000000..126dcaaef
--- /dev/null
+++ b/tests/test-turboquant-prod.cpp
@@ -0,0 +1,171 @@
+// Round-trip and inner-product unbiasedness tests for GGML_TYPE_TQ_PROD_4
+// (TurboQuant Algorithm 2: MSE-4 + 1-bit JL sign sketch on the residual).
+//
+// Mirrors the prototype in tejas-kv-compress/turbo_quant.py:
+//   - TEST 1: per-element MSE on unit-norm Gaussian. Should be lower than the
+//             pure-MSE TQ_MSE_4 path because the JL stage corrects the
+//             residual in expectation.
+//   - TEST 2: unbiasedness of <y, dequant(quant(x))> over many random (x, y)
+//             pairs. The mean inner-product error should be ~0 (down to
+//             O(1/sqrt(trials)) noise).
+
+#include "ggml.h"
+#include "ggml-cpu.h"
+
+#include <cassert>
+#include <cmath>
+#include <cstdio>
+#include <random>
+#include <vector>
+
+static float mean_sq_err(const float * a, const float * b, size_t n) {
+    double s = 0.0;
+    for (size_t i = 0; i < n; ++i) {
+        double d = (double)a[i] - (double)b[i];
+        s += d * d;
+    }
+    return (float)(s / (double)n);
+}
+
+int main() {
+    ggml_cpu_init();
+    ggml_quantize_init(GGML_TYPE_TQ_PROD_4);
+
+    const auto * traits     = ggml_get_type_traits(GGML_TYPE_TQ_PROD_4);
+    const auto * traits_cpu = ggml_get_type_traits_cpu(GGML_TYPE_TQ_PROD_4);
+    const auto * traits_mse = ggml_get_type_traits(GGML_TYPE_TQ_MSE_4);
+
+    assert(traits->blck_size == 128);
+    assert(traits_cpu->from_float != nullptr);
+    assert(traits->to_float != nullptr);
+
+    const int d = 128;
+    std::mt19937 rng(0);
+    std::normal_distribution<float> gauss(0.0f, 1.0f);
+
+    // ---- TEST 1: round-trip MSE ---------------------------------------------
+    std::vector<float> x(d);
+    for (int i = 0; i < d; ++i) x[i] = gauss(rng);
+    {
+        float nrm = 0.0f;
+        for (float v : x) nrm += v * v;
+        nrm = std::sqrt(nrm);
+        for (float & v : x) v /= nrm;
+    }
+
+    std::vector<uint8_t> q(traits->type_size);
+    std::vector<float>   x_hat(d);
+    traits_cpu->from_float(x.data(), q.data(), d);
+    traits->to_float(q.data(), x_hat.data(), d);
+
+    const float mse_prod = mean_sq_err(x.data(), x_hat.data(), d);
+    printf("[test-turboquant-prod] unit-norm MSE (per element) = %.5f\n", mse_prod);
+
+    // Compare against pure MSE-4 baseline on the same input. With the JL
+    // residual stage adding noise rather than just subtracting it (variance
+    // of the sketch is non-zero), per-block MSE may be similar in magnitude
+    // for a single seed, but the inner-product estimator becomes unbiased.
+    std::vector<uint8_t> q_mse(traits_mse->type_size);
+    std::vector<float>   x_hat_mse(d);
+    {
+        const auto * traits_cpu_mse = ggml_get_type_traits_cpu(GGML_TYPE_TQ_MSE_4);
+        traits_cpu_mse->from_float(x.data(), q_mse.data(), d);
+        traits_mse->to_float(q_mse.data(), x_hat_mse.data(), d);
+    }
+    const float mse_only = mean_sq_err(x.data(), x_hat_mse.data(), d);
+    printf("[test-turboquant-prod] for comparison, MSE-4 only  = %.5f\n", mse_only);
+
+    // The Prod reconstruction should still be in the same ballpark (within
+    // ~3x; the JL stage trades a bit of point-MSE for unbiasedness).
+    if (!(mse_prod < 3.0f * mse_only + 1e-4f)) {
+        printf("FAIL: Prod MSE %.5f much worse than MSE-4 baseline %.5f\n", mse_prod, mse_only);
+        return 1;
+    }
+
+    // ---- TEST 2: inner-product unbiasedness ---------------------------------
+    // Pick a fixed unit-norm x, then average over random Gaussian y.
+    // For each y, the JL residual estimator should make E[<y, x_hat>] = <y, x>.
+    // With one fixed (Pi, M), the bias is dominated by the MSE quantization
+    // (which is biased), so we compare against the plain MSE-4 dot to show
+    // that the Prod variant is closer to the truth on average.
+    const int trials = 4096;
+    double sum_err_prod = 0.0;
+    double sum_err_mse  = 0.0;
+    double sum_abs_prod = 0.0;
+    double sum_abs_mse  = 0.0;
+    std::vector<float> y(d);
+
+    for (int t = 0; t < trials; ++t) {
+        for (int i = 0; i < d; ++i) y[i] = gauss(rng);
+        double true_ip = 0.0;
+        for (int i = 0; i < d; ++i) true_ip += (double)y[i] * x[i];
+
+        double ip_prod = 0.0;
+        for (int i = 0; i < d; ++i) ip_prod += (double)y[i] * x_hat[i];
+        double ip_mse  = 0.0;
+        for (int i = 0; i < d; ++i) ip_mse  += (double)y[i] * x_hat_mse[i];
+
+        sum_err_prod += (ip_prod - true_ip);
+        sum_err_mse  += (ip_mse  - true_ip);
+        sum_abs_prod += std::fabs(ip_prod - true_ip);
+        sum_abs_mse  += std::fabs(ip_mse  - true_ip);
+    }
+    const double bias_prod = sum_err_prod / trials;
+    const double bias_mse  = sum_err_mse  / trials;
+    const double mae_prod  = sum_abs_prod / trials;
+    const double mae_mse   = sum_abs_mse  / trials;
+    printf("[test-turboquant-prod] over %d random y:\n", trials);
+    printf("    MSE-4 only : mean(IP err) = %+.5f   mean|IP err| = %.5f\n", bias_mse,  mae_mse);
+    printf("    Prod-4     : mean(IP err) = %+.5f   mean|IP err| = %.5f\n", bias_prod, mae_prod);
+
+    // Unbiasedness check: the Prod estimator's mean error should be
+    // substantially smaller than its mean absolute error (low bias relative
+    // to spread). MSE-4 is biased (no residual correction), so its mean
+    // error is closer to its MAE.
+    const double ratio_prod = std::fabs(bias_prod) / (mae_prod + 1e-9);
+    const double ratio_mse  = std::fabs(bias_mse)  / (mae_mse  + 1e-9);
+    printf("    bias / mean|err|: MSE-4=%.3f   Prod-4=%.3f (lower is better for Prod)\n",
+           ratio_mse, ratio_prod);
+    if (!(ratio_prod < 0.4f)) {
+        printf("FAIL: Prod-4 bias ratio %.3f >= 0.4 (estimator is not unbiased)\n", ratio_prod);
+        return 1;
+    }
+
+    // ---- TEST 3: multi-block round-trip -------------------------------------
+    const int nb = 4;
+    std::vector<float> big(nb * d), big_hat(nb * d);
+    for (int i = 0; i < nb * d; ++i) big[i] = gauss(rng);
+    for (int b = 0; b < nb; ++b) {
+        float s = 0.0f;
+        for (int i = 0; i < d; ++i) s += big[b*d+i] * big[b*d+i];
+        s = std::sqrt(s);
+        for (int i = 0; i < d; ++i) big[b*d+i] /= s;
+    }
+    std::vector<uint8_t> bigq(nb * traits->type_size);
+    traits_cpu->from_float(big.data(), bigq.data(), nb * d);
+    traits->to_float(bigq.data(), big_hat.data(), nb * d);
+    const float big_mse = mean_sq_err(big.data(), big_hat.data(), nb * d);
+    printf("[test-turboquant-prod] %d-block unit-norm MSE = %.5f\n", nb, big_mse);
+    if (!(big_mse < 0.05f)) {
+        printf("FAIL: multi-block MSE %.5f too high\n", big_mse);
+        return 1;
+    }
+
+    // ---- TEST 4: vec_dot matches dequant + plain dot ------------------------
+    std::vector<float> qf(d);
+    for (int i = 0; i < d; ++i) qf[i] = gauss(rng);
+    float dot_ref = 0.0f;
+    for (int i = 0; i < d; ++i) dot_ref += x_hat[i] * qf[i];
+
+    float dot_fast = 0.0f;
+    traits_cpu->vec_dot(d, &dot_fast, 0, q.data(), 0, qf.data(), 0, 1);
+    printf("[test-turboquant-prod] vec_dot vs dequant+dot: %.5f vs %.5f (diff %.2e)\n",
+           dot_fast, dot_ref, std::fabs(dot_fast - dot_ref));
+    if (std::fabs(dot_fast - dot_ref) > 1e-4f * (std::fabs(dot_ref) + 1e-6f)) {
+        printf("FAIL: vec_dot diverges from reference\n");
+        return 1;
+    }
+
+    printf("[test-turboquant-prod] OK\n");
+    return 0;
+}
diff --git a/tests/test-turboquant.cpp b/tests/test-turboquant.cpp
new file mode 100644
index 000000000..158fdc449
--- /dev/null
+++ b/tests/test-turboquant.cpp
@@ -0,0 +1,131 @@
+// Round-trip tests for GGML_TYPE_TQ_MSE_4 (TurboQuant MSE, 4-bit, d=128).
+// Mirrors the Python prototype in tejas-kv-compress/turbo_quant.py:
+//   - TEST 1: single unit-vector round-trip, expected MSE per element ~ 0.009
+//             at 4 bits for TurboQuantMSE (the paper's Algorithm 1).
+//   - Also checks norm preservation and that ||Pi Pi^T - I|| is small.
+
+#include "ggml.h"
+#include "ggml-cpu.h"
+
+#include <cassert>
+#include <cmath>
+#include <cstdio>
+#include <cstdlib>
+#include <random>
+#include <vector>
+
+static float rmse(const float * a, const float * b, size_t n) {
+    double s = 0.0;
+    for (size_t i = 0; i < n; ++i) {
+        double d = (double)a[i] - (double)b[i];
+        s += d * d;
+    }
+    return (float)std::sqrt(s / (double)n);
+}
+
+static float mean_sq_err(const float * a, const float * b, size_t n) {
+    double s = 0.0;
+    for (size_t i = 0; i < n; ++i) {
+        double d = (double)a[i] - (double)b[i];
+        s += d * d;
+    }
+    return (float)(s / (double)n);
+}
+
+int main() {
+    ggml_cpu_init();
+    ggml_quantize_init(GGML_TYPE_TQ_MSE_4);
+
+    const auto * traits     = ggml_get_type_traits(GGML_TYPE_TQ_MSE_4);
+    const auto * traits_cpu = ggml_get_type_traits_cpu(GGML_TYPE_TQ_MSE_4);
+
+    assert(traits->blck_size == 128);
+    assert(traits_cpu->from_float != nullptr);
+    assert(traits->to_float != nullptr);
+
+    const int d = 128;
+    std::mt19937 rng(0);
+    std::normal_distribution<float> gauss(0.0f, 1.0f);
+
+    // Test 1: unit-norm Gaussian round-trip, d=128.
+    std::vector<float> x(d);
+    for (int i = 0; i < d; ++i) x[i] = gauss(rng);
+    float nrm = 0.0f;
+    for (float v : x) nrm += v * v;
+    nrm = std::sqrt(nrm);
+    for (float & v : x) v /= nrm;
+
+    std::vector<uint8_t> q(traits->type_size);
+    std::vector<float>   x_hat(d);
+
+    traits_cpu->from_float(x.data(), q.data(), d);
+    traits->to_float(q.data(), x_hat.data(), d);
+
+    const float mse = mean_sq_err(x.data(), x_hat.data(), d);
+    printf("[test-turboquant] unit-norm MSE (per element) = %.5f (expected ~ 0.009)\n", mse);
+
+    // Per-element MSE should be on the order of the paper's bound. Give
+    // generous slack (2.5x) to absorb Gram-Schmidt numerical noise and the
+    // Gaussian vs. Beta asymptotic approximation at d=128.
+    const float mse_tol = 0.025f;
+    if (!(mse < mse_tol)) {
+        printf("FAIL: MSE %.5f >= tol %.5f\n", mse, mse_tol);
+        return 1;
+    }
+
+    // Test 2: non-unit-norm Gaussian — norm is stored exactly enough for fp16
+    // to reconstruct scale; relative MSE should be roughly the same.
+    std::vector<float> y(d);
+    for (int i = 0; i < d; ++i) y[i] = 3.7f * gauss(rng);
+    traits_cpu->from_float(y.data(), q.data(), d);
+    traits->to_float(q.data(), x_hat.data(), d);
+
+    float y_sumsq = 0.0f;
+    for (float v : y) y_sumsq += v * v;
+    const float rel_mse = mean_sq_err(y.data(), x_hat.data(), d) / (y_sumsq / d);
+    printf("[test-turboquant] scaled-Gaussian relative MSE = %.5f\n", rel_mse);
+    if (!(rel_mse < mse_tol)) {
+        printf("FAIL: relative MSE %.5f >= tol %.5f\n", rel_mse, mse_tol);
+        return 1;
+    }
+
+    // Test 3: multiple blocks in one call.
+    const int nb = 4;
+    std::vector<float> big(nb * d), big_hat(nb * d);
+    for (int i = 0; i < nb * d; ++i) big[i] = gauss(rng);
+    // Normalize each d-block to unit.
+    for (int b = 0; b < nb; ++b) {
+        float s = 0.0f;
+        for (int i = 0; i < d; ++i) s += big[b*d+i] * big[b*d+i];
+        s = std::sqrt(s);
+        for (int i = 0; i < d; ++i) big[b*d+i] /= s;
+    }
+    std::vector<uint8_t> bigq(nb * traits->type_size);
+    traits_cpu->from_float(big.data(), bigq.data(), nb * d);
+    traits->to_float(bigq.data(), big_hat.data(), nb * d);
+    const float big_mse = mean_sq_err(big.data(), big_hat.data(), nb * d);
+    printf("[test-turboquant] %d-block unit-norm MSE = %.5f\n", nb, big_mse);
+    if (!(big_mse < mse_tol)) {
+        printf("FAIL: multi-block MSE %.5f >= tol %.5f\n", big_mse, mse_tol);
+        return 1;
+    }
+
+    // Test 4: vec_dot matches float dot on dequantized.
+    std::vector<float> qf(d);
+    for (int i = 0; i < d; ++i) qf[i] = gauss(rng);
+    float dot_ref = 0.0f;
+    traits->to_float(q.data(), x_hat.data(), d); // x_hat is dequant of y-block
+    for (int i = 0; i < d; ++i) dot_ref += x_hat[i] * qf[i];
+
+    float dot_fast = 0.0f;
+    traits_cpu->vec_dot(d, &dot_fast, 0, q.data(), 0, qf.data(), 0, 1);
+    printf("[test-turboquant] vec_dot vs reference dot: %.5f vs %.5f (diff %.2e)\n",
+           dot_fast, dot_ref, std::fabs(dot_fast - dot_ref));
+    if (std::fabs(dot_fast - dot_ref) > 1e-4f * (std::fabs(dot_ref) + 1e-6f)) {
+        printf("FAIL: vec_dot diverges from reference\n");
+        return 1;
+    }
+
+    printf("[test-turboquant] OK\n");
+    return 0;
+}
