+// CUDA path for GGML_TYPE_TQ_PROD_4 (TurboQuant Algorithm 2: MSE-4 stage +
+// 1-bit JL sign sketch on the per-block residual).
+//
+// Reuses the CPU-built Pi / codebook tables from tq_mse_4_init_impl() and adds
+// a fresh dxd Gaussian sketch matrix M (and its transpose). All four host
+// tables are mirrored to __device__ memory on first use by
+// ggml_cuda_tq_prod_4_init.
+//
+// The CUDA path forces TQ_PROD_4 into the cuBLAS F32 fallback in mul_mat
+// (same approach as TQ_MSE_4): no fused vec-dot, no flash-attn template
+// instances. The ggml-cuda.cu supports_op switch allows CPY + MUL_MAT for
+// this type and excludes it from MMVQ / MMQ.
+
+void ggml_cuda_tq_prod_4_init(cudaStream_t stream);
+
+// F32 -> TQ_PROD_4 (KV-cache write path).
+void ggml_cuda_cpy_f32_to_tq_prod_4(
+        const char * cx, char * cdst, const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13,
+        cudaStream_t stream);
+
+// TQ_PROD_4 -> F32 (KV-cache read path used by the CPU-fallback matmul).
+void ggml_cuda_cpy_tq_prod_4_to_f32(
+        const char * cx, char * cdst, const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13,
+        cudaStream_t stream);
+
+// Contiguous dequant for the cuBLAS fallback matmul path.
+void ggml_cuda_dequantize_row_tq_prod_4_fp32(
+        const void * vx, float * y, int64_t k, cudaStream_t stream);
+void ggml_cuda_dequantize_row_tq_prod_4_fp16(
+        const void * vx, half  * y, int64_t k, cudaStream_t stream);
