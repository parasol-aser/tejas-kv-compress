diff --git a/ggml/src/ggml-cuda/tq_mse_4.cu b/ggml/src/ggml-cuda/tq_mse_4.cu
new file mode 100644
index 000000000..7b4fab355
--- /dev/null
+++ b/ggml/src/ggml-cuda/tq_mse_4.cu
@@ -0,0 +1,344 @@
+// CUDA port of GGML_TYPE_TQ_MSE_4 (TurboQuant MSE, 4-bit, d=128).
+//
+// The CPU reference (ggml/src/ggml-quants.c) owns the table construction
+// (xoshiro256** + Box-Muller + modified Gram-Schmidt) so both backends use
+// literally the same Pi and codebook. We just cudaMemcpyToSymbol the tables
+// across on first use.
+//
+// Scope of this first PoC:
+//   * F32 -> TQ_MSE_4  (KV cache write)
+//   * TQ_MSE_4 -> F32  (dequant for CPU-fallback matmul)
+//   * No quant-quant vec-dot, no flash-attn integration — the CUDA
+//     supports_op switch deliberately leaves GGML_TYPE_TQ_MSE_4 out of the
+//     mul_mat list so the backend scheduler falls back to CPU for attention.
+//
+// Perf notes (TODO for a follow-up):
+//   * The quantize kernel reads Pi row-major with a column-stride access
+//     pattern across threads, which is uncoalesced. A column-major copy of
+//     Pi would fix this. For correctness-first PoC this is fine.
+//   * The dequantize kernel's Pi^T access is already coalesced.
+//   * No fused vec-dot that exploits <y_rot, Pi q> — that's the real
+//     perf win and belongs in fattn-common.cuh, not here.
+
+#include "tq_mse_4.cuh"
+#include "ggml-quants.h"   // tq_mse_4_init_impl on the CPU side
+
+#include <mutex>
+
+#define TQ_D 128
+#define TQ_K 16   // 2^4 codebook entries
+
+// -----------------------------------------------------------------------------
+// Device-side tables.
+// -----------------------------------------------------------------------------
+// 128*128 = 16384 floats = 64 KB for each of Pi, Pi^T. __constant__ can't hold
+// 64 KB so we keep them in ordinary __device__ global memory.
+__device__ float d_tq_pi  [TQ_D * TQ_D];
+__device__ float d_tq_piT [TQ_D * TQ_D];
+__device__ float d_tq_codebook[TQ_K];
+
+static std::once_flag g_tq_cuda_init_flag;
+
+// -----------------------------------------------------------------------------
+// Host-side init: mirror the CPU tables onto the device once per process.
+// -----------------------------------------------------------------------------
+void ggml_cuda_tq_mse_4_init(cudaStream_t stream) {
+    std::call_once(g_tq_cuda_init_flag, [stream]() {
+        // Make sure the CPU-side build has happened. tq_mse_4_init_impl is a
+        // C API in ggml-quants.h and is itself idempotent / thread-safe.
+        tq_mse_4_init_impl();
+
+        // Pull the CPU tables out via the ref quant/dequant paths. They
+        // aren't exposed as C symbols, so we reconstruct them by doing a
+        // round-trip on known inputs... or we can just declare them extern.
+        // Simpler: expose the raw buffers. Since this file lives in the ggml
+        // tree we can pull them in via a small C helper.
+        extern const float * ggml_tq_mse_4_host_pi (void);
+        extern const float * ggml_tq_mse_4_host_piT(void);
+        extern const float * ggml_tq_mse_4_host_codebook(void);
+
+        const float * h_pi        = ggml_tq_mse_4_host_pi();
+        const float * h_piT       = ggml_tq_mse_4_host_piT();
+        const float * h_codebook  = ggml_tq_mse_4_host_codebook();
+
+        CUDA_CHECK(cudaMemcpyToSymbolAsync(d_tq_pi,       h_pi,       sizeof(float)*TQ_D*TQ_D, 0, cudaMemcpyHostToDevice, stream));
+        CUDA_CHECK(cudaMemcpyToSymbolAsync(d_tq_piT,      h_piT,      sizeof(float)*TQ_D*TQ_D, 0, cudaMemcpyHostToDevice, stream));
+        CUDA_CHECK(cudaMemcpyToSymbolAsync(d_tq_codebook, h_codebook, sizeof(float)*TQ_K,       0, cudaMemcpyHostToDevice, stream));
+        CUDA_CHECK(cudaStreamSynchronize(stream));
+    });
+}
+
+// -----------------------------------------------------------------------------
+// Helper: locate the source float row and destination block for CUDA block
+// index = linear output-block index `ib`.
+// -----------------------------------------------------------------------------
+// We pack the 4D indexing the same way cpy_f32_q does. 128 output elements
+// per TQ block, `i` is the flat element index of the first element in this
+// block.
+__device__ static inline void tq_src_dst_offsets(
+        int64_t ib,
+        int64_t ne00, int64_t ne01, int64_t ne02,
+        int64_t nb00, int64_t nb01, int64_t nb02, int64_t nb03,
+        int64_t ne10, int64_t ne11, int64_t ne12,
+        int64_t nb10, int64_t nb11, int64_t nb12, int64_t nb13,
+        int qk,
+        int64_t & x_offset, int64_t & dst_offset) {
+    const int64_t i = ib * qk;
+
+    const int64_t i03 = i / (ne00 * ne01 * ne02);
+    const int64_t i02 = (i - i03 * ne00 * ne01 * ne02) / (ne00 * ne01);
+    const int64_t i01 = (i - i03 * ne00 * ne01 * ne02 - i02 * ne01 * ne00) / ne00;
+    const int64_t i00 =  i - i03 * ne00 * ne01 * ne02 - i02 * ne01 * ne00 - i01 * ne00;
+    x_offset = i00 * nb00 + i01 * nb01 + i02 * nb02 + i03 * nb03;
+
+    const int64_t i13 = i / (ne10 * ne11 * ne12);
+    const int64_t i12 = (i - i13 * ne10 * ne11 * ne12) / (ne10 * ne11);
+    const int64_t i11 = (i - i13 * ne10 * ne11 * ne12 - i12 * ne10 * ne11) / ne10;
+    const int64_t i10 =  i - i13 * ne10 * ne11 * ne12 - i12 * ne10 * ne11 - i11 * ne10;
+    dst_offset = (i10 / qk) * nb10 + i11 * nb11 + i12 * nb12 + i13 * nb13;
+}
+
+// -----------------------------------------------------------------------------
+// Quantize kernel: F32 -> block_tq_mse_4. One CUDA block per TQ block, 128
+// threads. Each thread owns one of the 128 rotated coords.
+// -----------------------------------------------------------------------------
+__global__ static void cpy_f32_to_tq_mse_4_kernel(
+        const char * cx, char * cdst,
+        const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13) {
+
+    const int64_t ib = blockIdx.x;
+    if (ib * TQ_D >= ne) return;
+
+    int64_t x_offset, dst_offset;
+    tq_src_dst_offsets(ib,
+                       ne00, ne01, ne02, nb00, nb01, nb02, nb03,
+                       ne10, ne11, ne12, nb10, nb11, nb12, nb13,
+                       TQ_D, x_offset, dst_offset);
+
+    const float    * __restrict__ x = (const float *)(cx + x_offset);
+    block_tq_mse_4 * __restrict__ y = (block_tq_mse_4 *)(cdst + dst_offset);
+
+    const int t = threadIdx.x;  // 0..127
+
+    // 1. Stage x[] in shared memory for repeated reads during Pi * x.
+    __shared__ float x_sh[TQ_D];
+    x_sh[t] = x[t];
+    __syncthreads();
+
+    // 2. ||x||^2 via a shared-memory reduction.
+    __shared__ float reduce[TQ_D];
+    reduce[t] = x_sh[t] * x_sh[t];
+    __syncthreads();
+    for (int s = TQ_D / 2; s > 0; s >>= 1) {
+        if (t < s) reduce[t] += reduce[t + s];
+        __syncthreads();
+    }
+    const float norm     = sqrtf(reduce[0]);
+    const float inv_norm = (norm > 1e-20f) ? (1.0f / norm) : 0.0f;
+
+    // 3. y_rot[t] = (1/norm) * sum_j Pi[t, j] * x[j].
+    //    Pi is stored row-major with a 128-stride, so reads across threads at
+    //    fixed j are 128 floats apart — uncoalesced. Accepted for the PoC.
+    float yt = 0.0f;
+    #pragma unroll 8
+    for (int j = 0; j < TQ_D; ++j) {
+        yt += d_tq_pi[t * TQ_D + j] * x_sh[j];
+    }
+    yt *= inv_norm;
+
+    // 4. Find nearest codebook entry. Codebook is symmetric and ascending,
+    //    so a linear 16-way scan is fine.
+    int   best_i = 0;
+    float best_d = fabsf(yt - d_tq_codebook[0]);
+    #pragma unroll
+    for (int i = 1; i < TQ_K; ++i) {
+        const float d = fabsf(yt - d_tq_codebook[i]);
+        if (d < best_d) { best_d = d; best_i = i; }
+    }
+
+    // 5. Pack nibbles. Each byte qs[t/2] holds two 4-bit indices (low = even
+    //    thread, high = odd thread).
+    __shared__ uint8_t idx_sh[TQ_D];
+    idx_sh[t] = (uint8_t) best_i;
+    __syncthreads();
+
+    if (t < TQ_D / 2) {
+        const uint8_t lo = idx_sh[2*t    ];
+        const uint8_t hi = idx_sh[2*t + 1];
+        y->qs[t] = (uint8_t)((lo & 0x0F) | (hi << 4));
+    }
+
+    // 6. Store the scale. On CUDA ggml_half is __half, which has an
+    //    implicit float conversion.
+    if (t == 0) {
+        y->d = norm;
+    }
+}
+
+// -----------------------------------------------------------------------------
+// Dequantize kernel: block_tq_mse_4 -> F32. One CUDA block per TQ block,
+// 128 threads. Each thread owns one output coord x[t].
+// -----------------------------------------------------------------------------
+__global__ static void cpy_tq_mse_4_to_f32_kernel(
+        const char * cx, char * cdst,
+        const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13) {
+
+    const int64_t ib = blockIdx.x;
+    if (ib * TQ_D >= ne) return;
+
+    // The cpy_q_f32 kernel uses `(i00 / qk) * nb00` on the src side and a
+    // per-element stride on the dst side. Reuse its indexing logic:
+    const int64_t i = ib * TQ_D;
+
+    const int64_t i03 = i / (ne00 * ne01 * ne02);
+    const int64_t i02 = (i - i03 * ne00 * ne01 * ne02) / (ne00 * ne01);
+    const int64_t i01 = (i - i03 * ne00 * ne01 * ne02 - i02 * ne01 * ne00) / ne00;
+    const int64_t i00 =  i - i03 * ne00 * ne01 * ne02 - i02 * ne01 * ne00 - i01 * ne00;
+    const int64_t x_offset = (i00 / TQ_D) * nb00 + i01 * nb01 + i02 * nb02 + i03 * nb03;
+
+    const int64_t i13 = i / (ne10 * ne11 * ne12);
+    const int64_t i12 = (i - i13 * ne10 * ne11 * ne12) / (ne10 * ne11);
+    const int64_t i11 = (i - i13 * ne10 * ne11 * ne12 - i12 * ne10 * ne11) / ne10;
+    const int64_t i10 =  i - i13 * ne10 * ne11 * ne12 - i12 * ne10 * ne11 - i11 * ne10;
+    const int64_t dst_offset = i10 * nb10 + i11 * nb11 + i12 * nb12 + i13 * nb13;
+
+    const block_tq_mse_4 * __restrict__ x = (const block_tq_mse_4 *)(cx + x_offset);
+    float                * __restrict__ y = (float                *)(cdst + dst_offset);
+
+    const int t = threadIdx.x;  // 0..127
+
+    // 1. Unpack nibbles -> y_rot in shared memory.
+    __shared__ float y_rot[TQ_D];
+    if (t < TQ_D / 2) {
+        const uint8_t byte = x->qs[t];
+        y_rot[2*t    ] = d_tq_codebook[byte & 0x0F];
+        y_rot[2*t + 1] = d_tq_codebook[byte >>   4];
+    }
+    __syncthreads();
+
+    // 2. Read the fp16 scale. ggml_half == __half on CUDA; cast to float.
+    const float scale = (float) x->d;
+
+    // 3. x[t] = scale * sum_j Pi^T[t, j] * y_rot[j]
+    //    Pi^T stored row-major. Across warp lanes, at fixed j, threads t read
+    //    piT[t*128 + j] — strided 128 floats. Not coalesced in this layout
+    //    either. (Coalescing would need Pi^T stored column-major; fine for
+    //    the PoC.)
+    float acc = 0.0f;
+    #pragma unroll 8
+    for (int j = 0; j < TQ_D; ++j) {
+        acc += d_tq_piT[t * TQ_D + j] * y_rot[j];
+    }
+    y[t] = scale * acc;
+}
+
+// -----------------------------------------------------------------------------
+// Host launchers.
+// -----------------------------------------------------------------------------
+void ggml_cuda_cpy_f32_to_tq_mse_4(
+        const char * cx, char * cdst, const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13,
+        cudaStream_t stream) {
+
+    GGML_ASSERT(ne % TQ_D == 0);
+    const int64_t num_blocks = ne / TQ_D;
+    GGML_ASSERT(num_blocks < UINT_MAX);
+
+    ggml_cuda_tq_mse_4_init(stream);
+
+    cpy_f32_to_tq_mse_4_kernel<<<(unsigned)num_blocks, TQ_D, 0, stream>>>(
+        cx, cdst, ne,
+        ne00, ne01, ne02, nb00, nb01, nb02, nb03,
+        ne10, ne11, ne12, nb10, nb11, nb12, nb13);
+}
+
+void ggml_cuda_cpy_tq_mse_4_to_f32(
+        const char * cx, char * cdst, const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13,
+        cudaStream_t stream) {
+
+    GGML_ASSERT(ne % TQ_D == 0);
+    const int64_t num_blocks = ne / TQ_D;
+    GGML_ASSERT(num_blocks < UINT_MAX);
+
+    ggml_cuda_tq_mse_4_init(stream);
+
+    cpy_tq_mse_4_to_f32_kernel<<<(unsigned)num_blocks, TQ_D, 0, stream>>>(
+        cx, cdst, ne,
+        ne00, ne01, ne02, nb00, nb01, nb02, nb03,
+        ne10, ne11, ne12, nb10, nb11, nb12, nb13);
+}
+
+// -----------------------------------------------------------------------------
+// Contiguous dequant for the cuBLAS F32 fallback matmul path.
+//
+// Much simpler than the strided cpy path: input is a tightly-packed array of
+// blocks, output is a flat float buffer of length k = num_blocks * 128.
+// -----------------------------------------------------------------------------
+template <typename dst_t>
+__global__ static void dequantize_block_tq_mse_4_kernel(
+        const block_tq_mse_4 * __restrict__ x, dst_t * __restrict__ y, const int64_t nb) {
+
+    const int64_t ib = blockIdx.x;
+    if (ib >= nb) return;
+
+    const block_tq_mse_4 * xb = x + ib;
+    dst_t                * yb = y + ib * TQ_D;
+
+    const int t = threadIdx.x;  // 0..127
+
+    __shared__ float y_rot[TQ_D];
+    if (t < TQ_D / 2) {
+        const uint8_t byte = xb->qs[t];
+        y_rot[2*t    ] = d_tq_codebook[byte & 0x0F];
+        y_rot[2*t + 1] = d_tq_codebook[byte >>   4];
+    }
+    __syncthreads();
+
+    const float scale = (float) xb->d;
+
+    float acc = 0.0f;
+    #pragma unroll 8
+    for (int j = 0; j < TQ_D; ++j) {
+        acc += d_tq_piT[t * TQ_D + j] * y_rot[j];
+    }
+
+    const float out = scale * acc;
+    if constexpr (std::is_same_v<dst_t, half>) {
+        yb[t] = __float2half(out);
+    } else {
+        yb[t] = out;
+    }
+}
+
+void ggml_cuda_dequantize_row_tq_mse_4_fp32(
+        const void * vx, float * y, int64_t k, cudaStream_t stream) {
+    GGML_ASSERT(k % TQ_D == 0);
+    const int64_t nb = k / TQ_D;
+    ggml_cuda_tq_mse_4_init(stream);
+    dequantize_block_tq_mse_4_kernel<float><<<(unsigned)nb, TQ_D, 0, stream>>>(
+        (const block_tq_mse_4 *) vx, y, nb);
+}
+
+void ggml_cuda_dequantize_row_tq_mse_4_fp16(
+        const void * vx, half * y, int64_t k, cudaStream_t stream) {
+    GGML_ASSERT(k % TQ_D == 0);
+    const int64_t nb = k / TQ_D;
+    ggml_cuda_tq_mse_4_init(stream);
+    dequantize_block_tq_mse_4_kernel<half><<<(unsigned)nb, TQ_D, 0, stream>>>(
+        (const block_tq_mse_4 *) vx, y, nb);
+}
diff --git a/ggml/src/ggml-cuda/tq_mse_4.cuh b/ggml/src/ggml-cuda/tq_mse_4.cuh
new file mode 100644
index 000000000..ec8db107e
--- /dev/null
+++ b/ggml/src/ggml-cuda/tq_mse_4.cuh
@@ -0,0 +1,45 @@
+#pragma once
+
+#include "common.cuh"
+
+// CUDA path for GGML_TYPE_TQ_MSE_4 (TurboQuant MSE, 4-bit, d=128).
+//
+// The rotation matrix Pi and the 16-entry codebook are built on the CPU by
+// tq_mse_4_init_impl() (see ggml/src/ggml-quants.c) and then copied to
+// device-side tables on first use by ggml_cuda_tq_mse_4_init(). This
+// guarantees bit-identical Pi / codebook across CPU and CUDA so a round
+// trip through either backend is byte-exact.
+//
+// Host entrypoints:
+
+// Call once (implicitly from cpy wrappers) to push CPU tables to device.
+void ggml_cuda_tq_mse_4_init(cudaStream_t stream);
+
+// F32 src -> TQ_MSE_4 dst (KV-cache write path). The "ne*" / "nb*" args are
+// the same ones that the generic cpy_f32_q kernel takes — we need them to
+// walk the 4D tensor.
+void ggml_cuda_cpy_f32_to_tq_mse_4(
+        const char * cx, char * cdst, const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13,
+        cudaStream_t stream);
+
+// TQ_MSE_4 src -> F32 dst (KV-cache read path used by the CPU-fallback
+// matmul; see supports_op in ggml-cuda.cu).
+void ggml_cuda_cpy_tq_mse_4_to_f32(
+        const char * cx, char * cdst, const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13,
+        cudaStream_t stream);
+
+// Contiguous dequant for the cuBLAS F32 fallback matmul path.
+// Signature matches `to_fp32_cuda_t` in convert.cuh:
+//     (const void * vx, float * y, int64_t k, cudaStream_t stream)
+void ggml_cuda_dequantize_row_tq_mse_4_fp32(
+        const void * vx, float * y, int64_t k, cudaStream_t stream);
+void ggml_cuda_dequantize_row_tq_mse_4_fp16(
+        const void * vx, half  * y, int64_t k, cudaStream_t stream);
diff --git a/ggml/src/ggml-cuda/tq_prod_4.cu b/ggml/src/ggml-cuda/tq_prod_4.cu
new file mode 100644
index 000000000..5eeef0959
--- /dev/null
+++ b/ggml/src/ggml-cuda/tq_prod_4.cu
@@ -0,0 +1,410 @@
+// CUDA port of GGML_TYPE_TQ_PROD_4 (TurboQuant Algorithm 2:
+// MSE-4 stage + 1-bit JL sign sketch on the per-block residual).
+//
+// Reuses the Pi / codebook tables from tq_mse_4.cu (those are already
+// __device__ globals from the MSE port). Adds a sketch matrix M (and its
+// transpose) built on the CPU from a distinct PRNG seed, mirrored here via
+// cudaMemcpyToSymbol.
+//
+// Scope of this PoC:
+//   * F32 -> TQ_PROD_4   (KV cache write)
+//   * TQ_PROD_4 -> F32   (dequant for cuBLAS fallback matmul)
+//   * Contiguous dequant to F32 / F16 for the cuBLAS fallback path
+//   * No quant-quant vec-dot, no flash-attn integration — same constraints
+//     as TQ_MSE_4 (the supports_op switch in ggml-cuda.cu deliberately
+//     excludes both types from MMVQ / MMQ).
+//
+// Perf notes (TODO follow-up): Pi reads in the quantize kernel are still
+// uncoalesced; M reads in the sketch kernel are uncoalesced too. A column-
+// major mirror of each would fix both. Correctness-first PoC.
+
+#include "tq_prod_4.cuh"
+#include "tq_mse_4.cuh"   // for ggml_cuda_tq_mse_4_init (chains the MSE init)
+#include "ggml-quants.h"  // for tq_prod_4_init_impl + host accessors
+
+#include <mutex>
+
+#define TQ_D 128
+#define TQ_K 16   // 2^4 codebook entries (shared with MSE stage)
+
+// -----------------------------------------------------------------------------
+// Device-side tables.
+//
+// Pi, Pi^T and the codebook live as __device__ globals in tq_mse_4.cu. We
+// declare them extern here to reuse them. M and M^T are owned by this file.
+// -----------------------------------------------------------------------------
+extern __device__ float d_tq_pi  [TQ_D * TQ_D];
+extern __device__ float d_tq_piT [TQ_D * TQ_D];
+extern __device__ float d_tq_codebook[TQ_K];
+
+__device__ float d_tq_prod_M  [TQ_D * TQ_D];
+__device__ float d_tq_prod_MT [TQ_D * TQ_D];
+
+// (sqrt(pi/2) / d) is the inverse JL constant.
+//   sqrt(pi/2) = 1.2533141373155...   ; divided by d=128 gives:
+static constexpr float TQ_PROD_JL_COEF = 1.2533141373155f / 128.0f;
+
+static std::once_flag g_tq_prod_cuda_init_flag;
+
+// -----------------------------------------------------------------------------
+// Host-side init: chain into the MSE init (so Pi / codebook get uploaded too)
+// then copy M and M^T over.
+// -----------------------------------------------------------------------------
+void ggml_cuda_tq_prod_4_init(cudaStream_t stream) {
+    // Make sure the MSE tables are on-device first. ggml_cuda_tq_mse_4_init is
+    // itself once_flag-guarded, so this is cheap on subsequent calls.
+    ggml_cuda_tq_mse_4_init(stream);
+
+    std::call_once(g_tq_prod_cuda_init_flag, [stream]() {
+        // CPU init for M (also re-runs the MSE init internally; idempotent).
+        tq_prod_4_init_impl();
+
+        const float * h_M  = ggml_tq_prod_4_host_M();
+        const float * h_MT = ggml_tq_prod_4_host_MT();
+
+        CUDA_CHECK(cudaMemcpyToSymbolAsync(d_tq_prod_M,  h_M,  sizeof(float)*TQ_D*TQ_D, 0, cudaMemcpyHostToDevice, stream));
+        CUDA_CHECK(cudaMemcpyToSymbolAsync(d_tq_prod_MT, h_MT, sizeof(float)*TQ_D*TQ_D, 0, cudaMemcpyHostToDevice, stream));
+        CUDA_CHECK(cudaStreamSynchronize(stream));
+    });
+}
+
+// -----------------------------------------------------------------------------
+// Helper: same indexing as tq_mse_4.cu (kept inline rather than shared so each
+// file is self-contained for the patch).
+// -----------------------------------------------------------------------------
+__device__ static inline void tq_prod_src_dst_offsets(
+        int64_t ib,
+        int64_t ne00, int64_t ne01, int64_t ne02,
+        int64_t nb00, int64_t nb01, int64_t nb02, int64_t nb03,
+        int64_t ne10, int64_t ne11, int64_t ne12,
+        int64_t nb10, int64_t nb11, int64_t nb12, int64_t nb13,
+        int qk,
+        int64_t & x_offset, int64_t & dst_offset) {
+    const int64_t i = ib * qk;
+
+    const int64_t i03 = i / (ne00 * ne01 * ne02);
+    const int64_t i02 = (i - i03 * ne00 * ne01 * ne02) / (ne00 * ne01);
+    const int64_t i01 = (i - i03 * ne00 * ne01 * ne02 - i02 * ne01 * ne00) / ne00;
+    const int64_t i00 =  i - i03 * ne00 * ne01 * ne02 - i02 * ne01 * ne00 - i01 * ne00;
+    x_offset = i00 * nb00 + i01 * nb01 + i02 * nb02 + i03 * nb03;
+
+    const int64_t i13 = i / (ne10 * ne11 * ne12);
+    const int64_t i12 = (i - i13 * ne10 * ne11 * ne12) / (ne10 * ne11);
+    const int64_t i11 = (i - i13 * ne10 * ne11 * ne12 - i12 * ne10 * ne11) / ne10;
+    const int64_t i10 =  i - i13 * ne10 * ne11 * ne12 - i12 * ne10 * ne11 - i11 * ne10;
+    dst_offset = (i10 / qk) * nb10 + i11 * nb11 + i12 * nb12 + i13 * nb13;
+}
+
+// -----------------------------------------------------------------------------
+// Quantize kernel: F32 -> block_tq_prod_4. One CUDA block per TQ block, 128
+// threads. Each thread owns one rotated coordinate (and produces one MSE index
+// + one JL sign bit).
+// -----------------------------------------------------------------------------
+__global__ static void cpy_f32_to_tq_prod_4_kernel(
+        const char * cx, char * cdst,
+        const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13) {
+
+    const int64_t ib = blockIdx.x;
+    if (ib * TQ_D >= ne) return;
+
+    int64_t x_offset, dst_offset;
+    tq_prod_src_dst_offsets(ib,
+                            ne00, ne01, ne02, nb00, nb01, nb02, nb03,
+                            ne10, ne11, ne12, nb10, nb11, nb12, nb13,
+                            TQ_D, x_offset, dst_offset);
+
+    const float     * __restrict__ x = (const float *)(cx + x_offset);
+    block_tq_prod_4 * __restrict__ y = (block_tq_prod_4 *)(cdst + dst_offset);
+
+    const int t = threadIdx.x;  // 0..127
+
+    // 1. Stage x[] in shared memory.
+    __shared__ float x_sh[TQ_D];
+    x_sh[t] = x[t];
+    __syncthreads();
+
+    // 2. ||x||^2 reduction.
+    __shared__ float reduce[TQ_D];
+    reduce[t] = x_sh[t] * x_sh[t];
+    __syncthreads();
+    for (int s = TQ_D / 2; s > 0; s >>= 1) {
+        if (t < s) reduce[t] += reduce[t + s];
+        __syncthreads();
+    }
+    const float norm     = sqrtf(reduce[0]);
+    const float inv_norm = (norm > 1e-20f) ? (1.0f / norm) : 0.0f;
+
+    // 3. y_rot[t] = (1/norm) * sum_j Pi[t, j] * x[j].
+    float yt = 0.0f;
+    #pragma unroll 8
+    for (int j = 0; j < TQ_D; ++j) {
+        yt += d_tq_pi[t * TQ_D + j] * x_sh[j];
+    }
+    yt *= inv_norm;
+
+    // 4. Find nearest codebook entry; compute residual coord r_rot[t].
+    int   best_i = 0;
+    float best_d = fabsf(yt - d_tq_codebook[0]);
+    #pragma unroll
+    for (int i = 1; i < TQ_K; ++i) {
+        const float d = fabsf(yt - d_tq_codebook[i]);
+        if (d < best_d) { best_d = d; best_i = i; }
+    }
+    const float rt = yt - d_tq_codebook[best_i];
+
+    // 5. Pack MSE nibbles.
+    __shared__ uint8_t idx_sh[TQ_D];
+    idx_sh[t] = (uint8_t) best_i;
+    __syncthreads();
+
+    if (t < TQ_D / 2) {
+        const uint8_t lo = idx_sh[2*t    ];
+        const uint8_t hi = idx_sh[2*t + 1];
+        y->qs[t] = (uint8_t)((lo & 0x0F) | (hi << 4));
+    }
+
+    // 6. gamma = ||r_rot|| via shared-mem reduction (reuse `reduce`).
+    __syncthreads();
+    reduce[t] = rt * rt;
+    __syncthreads();
+    for (int s = TQ_D / 2; s > 0; s >>= 1) {
+        if (t < s) reduce[t] += reduce[t + s];
+        __syncthreads();
+    }
+    const float gamma = sqrtf(reduce[0]);
+
+    // 7. Stage residual in shared memory for the JL sketch.
+    __shared__ float r_sh[TQ_D];
+    r_sh[t] = rt;
+    __syncthreads();
+
+    // 8. Sketch: each thread t computes (M @ r_rot)[t] and emits a sign bit.
+    float sr = 0.0f;
+    #pragma unroll 8
+    for (int j = 0; j < TQ_D; ++j) {
+        sr += d_tq_prod_M[t * TQ_D + j] * r_sh[j];
+    }
+    const uint8_t bit = (sr >= 0.0f) ? 1u : 0u;
+
+    // 9. Pack 8 sign bits per byte (LSB first within each byte). Threads
+    //    cooperate per-byte using a shared scratch.
+    __shared__ uint8_t bit_sh[TQ_D];
+    bit_sh[t] = bit;
+    __syncthreads();
+
+    if (t < TQ_D / 8) {
+        uint8_t b = 0;
+        #pragma unroll
+        for (int k = 0; k < 8; ++k) {
+            b |= (uint8_t)((bit_sh[8*t + k] & 1u) << k);
+        }
+        y->qjl[t] = b;
+    }
+
+    // 10. Store the two scalars.
+    if (t == 0) {
+        y->d     = norm;
+        y->gamma = gamma;
+    }
+}
+
+// -----------------------------------------------------------------------------
+// Dequantize kernel: block_tq_prod_4 -> F32. One CUDA block per TQ block,
+// 128 threads. Each thread owns one output coord x[t].
+// -----------------------------------------------------------------------------
+__global__ static void cpy_tq_prod_4_to_f32_kernel(
+        const char * cx, char * cdst,
+        const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13) {
+
+    const int64_t ib = blockIdx.x;
+    if (ib * TQ_D >= ne) return;
+
+    const int64_t i = ib * TQ_D;
+
+    const int64_t i03 = i / (ne00 * ne01 * ne02);
+    const int64_t i02 = (i - i03 * ne00 * ne01 * ne02) / (ne00 * ne01);
+    const int64_t i01 = (i - i03 * ne00 * ne01 * ne02 - i02 * ne01 * ne00) / ne00;
+    const int64_t i00 =  i - i03 * ne00 * ne01 * ne02 - i02 * ne01 * ne00 - i01 * ne00;
+    const int64_t x_offset = (i00 / TQ_D) * nb00 + i01 * nb01 + i02 * nb02 + i03 * nb03;
+
+    const int64_t i13 = i / (ne10 * ne11 * ne12);
+    const int64_t i12 = (i - i13 * ne10 * ne11 * ne12) / (ne10 * ne11);
+    const int64_t i11 = (i - i13 * ne10 * ne11 * ne12 - i12 * ne10 * ne11) / ne10;
+    const int64_t i10 =  i - i13 * ne10 * ne11 * ne12 - i12 * ne10 * ne11 - i11 * ne10;
+    const int64_t dst_offset = i10 * nb10 + i11 * nb11 + i12 * nb12 + i13 * nb13;
+
+    const block_tq_prod_4 * __restrict__ x = (const block_tq_prod_4 *)(cx + x_offset);
+    float                 * __restrict__ y = (float                 *)(cdst + dst_offset);
+
+    const int t = threadIdx.x;  // 0..127
+
+    // 1. Unpack MSE nibbles -> y_rot in shared memory.
+    __shared__ float y_rot[TQ_D];
+    if (t < TQ_D / 2) {
+        const uint8_t byte = x->qs[t];
+        y_rot[2*t    ] = d_tq_codebook[byte & 0x0F];
+        y_rot[2*t + 1] = d_tq_codebook[byte >>   4];
+    }
+
+    // 2. Unpack JL sign bits to +/-1 floats in shared memory.
+    __shared__ float qjl_sh[TQ_D];
+    if (t < TQ_D / 8) {
+        const uint8_t b = x->qjl[t];
+        #pragma unroll
+        for (int k = 0; k < 8; ++k) {
+            qjl_sh[8*t + k] = ((b >> k) & 1u) ? 1.0f : -1.0f;
+        }
+    }
+    __syncthreads();
+
+    // 3. y_full_rot[t] = y_rot[t] + (sqrt(pi/2)/d) * gamma * (M^T @ qjl)[t]
+    const float gamma = (float) x->gamma;
+    const float jl_c  = TQ_PROD_JL_COEF * gamma;
+    float jl_acc = 0.0f;
+    #pragma unroll 8
+    for (int j = 0; j < TQ_D; ++j) {
+        jl_acc += d_tq_prod_MT[t * TQ_D + j] * qjl_sh[j];
+    }
+
+    // Stash the corrected rotated coordinate so the next stage sees it.
+    __shared__ float y_full[TQ_D];
+    y_full[t] = y_rot[t] + jl_c * jl_acc;
+    __syncthreads();
+
+    // 4. x[t] = scale * sum_j Pi^T[t, j] * y_full[j]
+    const float scale = (float) x->d;
+    float acc = 0.0f;
+    #pragma unroll 8
+    for (int j = 0; j < TQ_D; ++j) {
+        acc += d_tq_piT[t * TQ_D + j] * y_full[j];
+    }
+    y[t] = scale * acc;
+}
+
+// -----------------------------------------------------------------------------
+// Host launchers.
+// -----------------------------------------------------------------------------
+void ggml_cuda_cpy_f32_to_tq_prod_4(
+        const char * cx, char * cdst, const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13,
+        cudaStream_t stream) {
+
+    GGML_ASSERT(ne % TQ_D == 0);
+    const int64_t num_blocks = ne / TQ_D;
+    GGML_ASSERT(num_blocks < UINT_MAX);
+
+    ggml_cuda_tq_prod_4_init(stream);
+
+    cpy_f32_to_tq_prod_4_kernel<<<(unsigned)num_blocks, TQ_D, 0, stream>>>(
+        cx, cdst, ne,
+        ne00, ne01, ne02, nb00, nb01, nb02, nb03,
+        ne10, ne11, ne12, nb10, nb11, nb12, nb13);
+}
+
+void ggml_cuda_cpy_tq_prod_4_to_f32(
+        const char * cx, char * cdst, const int64_t ne,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02,
+        const int64_t nb00, const int64_t nb01, const int64_t nb02, const int64_t nb03,
+        const int64_t ne10, const int64_t ne11, const int64_t ne12,
+        const int64_t nb10, const int64_t nb11, const int64_t nb12, const int64_t nb13,
+        cudaStream_t stream) {
+
+    GGML_ASSERT(ne % TQ_D == 0);
+    const int64_t num_blocks = ne / TQ_D;
+    GGML_ASSERT(num_blocks < UINT_MAX);
+
+    ggml_cuda_tq_prod_4_init(stream);
+
+    cpy_tq_prod_4_to_f32_kernel<<<(unsigned)num_blocks, TQ_D, 0, stream>>>(
+        cx, cdst, ne,
+        ne00, ne01, ne02, nb00, nb01, nb02, nb03,
+        ne10, ne11, ne12, nb10, nb11, nb12, nb13);
+}
+
+// -----------------------------------------------------------------------------
+// Contiguous dequant for the cuBLAS F32 fallback matmul path.
+// -----------------------------------------------------------------------------
+template <typename dst_t>
+__global__ static void dequantize_block_tq_prod_4_kernel(
+        const block_tq_prod_4 * __restrict__ x, dst_t * __restrict__ y, const int64_t nb) {
+
+    const int64_t ib = blockIdx.x;
+    if (ib >= nb) return;
+
+    const block_tq_prod_4 * xb = x + ib;
+    dst_t                 * yb = y + ib * TQ_D;
+
+    const int t = threadIdx.x;  // 0..127
+
+    __shared__ float y_rot[TQ_D];
+    if (t < TQ_D / 2) {
+        const uint8_t byte = xb->qs[t];
+        y_rot[2*t    ] = d_tq_codebook[byte & 0x0F];
+        y_rot[2*t + 1] = d_tq_codebook[byte >>   4];
+    }
+
+    __shared__ float qjl_sh[TQ_D];
+    if (t < TQ_D / 8) {
+        const uint8_t b = xb->qjl[t];
+        #pragma unroll
+        for (int k = 0; k < 8; ++k) {
+            qjl_sh[8*t + k] = ((b >> k) & 1u) ? 1.0f : -1.0f;
+        }
+    }
+    __syncthreads();
+
+    const float gamma = (float) xb->gamma;
+    const float jl_c  = TQ_PROD_JL_COEF * gamma;
+    float jl_acc = 0.0f;
+    #pragma unroll 8
+    for (int j = 0; j < TQ_D; ++j) {
+        jl_acc += d_tq_prod_MT[t * TQ_D + j] * qjl_sh[j];
+    }
+
+    __shared__ float y_full[TQ_D];
+    y_full[t] = y_rot[t] + jl_c * jl_acc;
+    __syncthreads();
+
+    const float scale = (float) xb->d;
+    float acc = 0.0f;
+    #pragma unroll 8
+    for (int j = 0; j < TQ_D; ++j) {
+        acc += d_tq_piT[t * TQ_D + j] * y_full[j];
+    }
+
+    const float out = scale * acc;
+    if constexpr (std::is_same_v<dst_t, half>) {
+        yb[t] = __float2half(out);
+    } else {
+        yb[t] = out;
+    }
+}
+
+void ggml_cuda_dequantize_row_tq_prod_4_fp32(
+        const void * vx, float * y, int64_t k, cudaStream_t stream) {
+    GGML_ASSERT(k % TQ_D == 0);
+    const int64_t nb = k / TQ_D;
+    ggml_cuda_tq_prod_4_init(stream);
+    dequantize_block_tq_prod_4_kernel<float><<<(unsigned)nb, TQ_D, 0, stream>>>(
+        (const block_tq_prod_4 *) vx, y, nb);
+}
+
+void ggml_cuda_dequantize_row_tq_prod_4_fp16(
+        const void * vx, half * y, int64_t k, cudaStream_t stream) {
+    GGML_ASSERT(k % TQ_D == 0);
+    const int64_t nb = k / TQ_D;
+    ggml_cuda_tq_prod_4_init(stream);
+    dequantize_block_tq_prod_4_kernel<half><<<(unsigned)nb, TQ_D, 0, stream>>>(
+        (const block_tq_prod_4 *) vx, y, nb);
+}
