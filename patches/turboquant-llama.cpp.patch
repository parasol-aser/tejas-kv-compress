diff --git a/tests/test-turboquant-cuda.cpp b/tests/test-turboquant-cuda.cpp
new file mode 100644
index 000000000..7c06da3db
--- /dev/null
+++ b/tests/test-turboquant-cuda.cpp
@@ -0,0 +1,206 @@
+// CPU ↔ CUDA parity test for GGML_TYPE_TQ_MSE_4.
+//
+// Builds the type tables on both backends from the same deterministic
+// PRNG seed, then verifies all four cross-backend round-trips match:
+//
+//    x  --cpu_quant-->  q  --cpu_dequant-->  x_hat_cpu_cpu
+//    x  --cpu_quant-->  q  --gpu_dequant-->  x_hat_cpu_gpu
+//    x  --gpu_quant-->  q  --cpu_dequant-->  x_hat_gpu_cpu
+//    x  --gpu_quant-->  q  --gpu_dequant-->  x_hat_gpu_gpu
+//
+// Since both backends share literally the same Pi / codebook (CPU builds
+// the tables and CUDA cudaMemcpyToSymbols them), we expect:
+//   - q buffers to be byte-identical between CPU and GPU quant paths
+//   - x_hat arrays to agree to a few ULPs (Pi^T·y matmul order differs)
+//
+// Requires a CUDA backend. If compiled without CUDA, skips.
+
+#include "ggml.h"
+#include "ggml-cpu.h"
+#include "ggml-backend.h"
+#include "ggml-alloc.h"
+
+#include <cassert>
+#include <cmath>
+#include <cstdio>
+#include <cstring>
+#include <random>
+#include <string>
+#include <vector>
+
+static float mean_sq_err(const float * a, const float * b, size_t n) {
+    double s = 0.0;
+    for (size_t i = 0; i < n; ++i) {
+        double d = (double)a[i] - (double)b[i];
+        s += d * d;
+    }
+    return (float)(s / (double)n);
+}
+
+static float max_abs_err(const float * a, const float * b, size_t n) {
+    float m = 0.0f;
+    for (size_t i = 0; i < n; ++i) {
+        float d = std::fabs(a[i] - b[i]);
+        if (d > m) m = d;
+    }
+    return m;
+}
+
+static ggml_backend_t find_cuda_backend() {
+    const size_t n = ggml_backend_reg_count();
+    for (size_t i = 0; i < n; ++i) {
+        ggml_backend_reg_t reg = ggml_backend_reg_get(i);
+        const char * name = ggml_backend_reg_name(reg);
+        if (name && std::string(name).find("CUDA") != std::string::npos) {
+            const size_t nd = ggml_backend_reg_dev_count(reg);
+            if (nd == 0) continue;
+            ggml_backend_dev_t dev = ggml_backend_reg_dev_get(reg, 0);
+            return ggml_backend_dev_init(dev, /*params=*/nullptr);
+        }
+    }
+    return nullptr;
+}
+
+// Create a 1-tensor graph that copies src -> dst (i.e. what ggml-cpy does).
+// Both tensors are allocated in `backend`'s buffer. We return the result as
+// a host-side vector.
+template <typename T>
+static std::vector<T> run_cpy_on_backend(
+        ggml_backend_t backend,
+        const float * x_host, ggml_type src_type, ggml_type dst_type,
+        int64_t n_elements) {
+    // Each tensor is a 1D row of length n_elements.
+    ggml_init_params ctx_params = { /*.mem_size=*/ 16*1024*1024,
+                                     /*.mem_buffer=*/ nullptr,
+                                     /*.no_alloc=*/ true };
+    ggml_context * ctx = ggml_init(ctx_params);
+
+    ggml_tensor * src = ggml_new_tensor_1d(ctx, src_type, n_elements);
+    ggml_tensor * dst = ggml_new_tensor_1d(ctx, dst_type, n_elements);
+    ggml_set_name(src, "src");
+    ggml_set_name(dst, "dst");
+
+    ggml_cgraph * gf = ggml_new_graph(ctx);
+    ggml_tensor * cpy = ggml_cpy(ctx, src, dst);
+    ggml_build_forward_expand(gf, cpy);
+
+    ggml_backend_buffer_t buf = ggml_backend_alloc_ctx_tensors(ctx, backend);
+    GGML_ASSERT(buf != nullptr);
+
+    // Upload src data. If src is quantized, x_host is already in packed form;
+    // if src is float, x_host is a normal float row.
+    const size_t bytes_src = ggml_nbytes(src);
+    ggml_backend_tensor_set(src, x_host, 0, bytes_src);
+
+    ggml_backend_graph_compute(backend, gf);
+
+    const size_t bytes_dst = ggml_nbytes(dst);
+    std::vector<T> out(bytes_dst / sizeof(T));
+    ggml_backend_tensor_get(dst, out.data(), 0, bytes_dst);
+
+    ggml_backend_buffer_free(buf);
+    ggml_free(ctx);
+    return out;
+}
+
+int main() {
+    ggml_backend_load_all();
+    ggml_cpu_init();
+
+    ggml_backend_t cpu = ggml_backend_cpu_init();
+    ggml_backend_t gpu = find_cuda_backend();
+
+    if (!gpu) {
+        printf("[test-turboquant-cuda] SKIP: no CUDA backend available.\n");
+        ggml_backend_free(cpu);
+        return 0;
+    }
+
+    // Touch the CPU tables so the CPU build has happened before we compare
+    // against GPU output (which pulls the same tables via cudaMemcpyToSymbol).
+    ggml_quantize_init(GGML_TYPE_TQ_MSE_4);
+
+    const int64_t N_BLOCKS = 8;
+    const int64_t n        = N_BLOCKS * 128;
+
+    std::mt19937 rng(17);
+    std::normal_distribution<float> gauss(0.0f, 1.0f);
+
+    std::vector<float> x(n);
+    for (int64_t i = 0; i < n; ++i) x[i] = gauss(rng);
+
+    // ---- 1. quant on each backend, compare packed bytes --------------------
+    auto q_cpu = run_cpy_on_backend<uint8_t>(cpu, x.data(), GGML_TYPE_F32, GGML_TYPE_TQ_MSE_4, n);
+    auto q_gpu = run_cpy_on_backend<uint8_t>(gpu, x.data(), GGML_TYPE_F32, GGML_TYPE_TQ_MSE_4, n);
+
+    assert(q_cpu.size() == q_gpu.size());
+    int byte_diffs = 0;
+    for (size_t i = 0; i < q_cpu.size(); ++i) {
+        if (q_cpu[i] != q_gpu[i]) ++byte_diffs;
+    }
+    printf("[test-turboquant-cuda] packed-bytes: %d/%zu differ between CPU and GPU quant\n",
+           byte_diffs, q_cpu.size());
+
+    // A few byte differs are acceptable if a rotated coord lands exactly on
+    // a codebook midpoint (different rounding direction on CPU vs GPU). The
+    // real test is whether the reconstructions agree numerically.
+    if (byte_diffs > (int)(q_cpu.size() / 20)) {
+        printf("FAIL: too many packed-byte mismatches (> 5%%)\n");
+        return 1;
+    }
+
+    // ---- 2. dequant(cpu_q) on each backend ---------------------------------
+    auto deq_cpu_from_cpu = run_cpy_on_backend<float>(cpu, (const float *)q_cpu.data(), GGML_TYPE_TQ_MSE_4, GGML_TYPE_F32, n);
+    auto deq_gpu_from_cpu = run_cpy_on_backend<float>(gpu, (const float *)q_cpu.data(), GGML_TYPE_TQ_MSE_4, GGML_TYPE_F32, n);
+
+    const float tol_mse = 1e-5f;   // matmul order differs, so allow some ULP noise
+    const float tol_max = 5e-3f;
+
+    const float mse_cc_gc = mean_sq_err(deq_cpu_from_cpu.data(), deq_gpu_from_cpu.data(), n);
+    const float mxe_cc_gc = max_abs_err(deq_cpu_from_cpu.data(), deq_gpu_from_cpu.data(), n);
+    printf("[test-turboquant-cuda] dequant parity (cpu_q → cpu vs gpu): mse=%.2e max_abs=%.2e\n",
+           mse_cc_gc, mxe_cc_gc);
+    if (!(mse_cc_gc < tol_mse && mxe_cc_gc < tol_max)) {
+        printf("FAIL: dequant(cpu_q) diverges between backends\n");
+        return 1;
+    }
+
+    // ---- 3. dequant(gpu_q) on each backend ---------------------------------
+    auto deq_cpu_from_gpu = run_cpy_on_backend<float>(cpu, (const float *)q_gpu.data(), GGML_TYPE_TQ_MSE_4, GGML_TYPE_F32, n);
+    auto deq_gpu_from_gpu = run_cpy_on_backend<float>(gpu, (const float *)q_gpu.data(), GGML_TYPE_TQ_MSE_4, GGML_TYPE_F32, n);
+
+    const float mse_cg_gg = mean_sq_err(deq_cpu_from_gpu.data(), deq_gpu_from_gpu.data(), n);
+    const float mxe_cg_gg = max_abs_err(deq_cpu_from_gpu.data(), deq_gpu_from_gpu.data(), n);
+    printf("[test-turboquant-cuda] dequant parity (gpu_q → cpu vs gpu): mse=%.2e max_abs=%.2e\n",
+           mse_cg_gg, mxe_cg_gg);
+    if (!(mse_cg_gg < tol_mse && mxe_cg_gg < tol_max)) {
+        printf("FAIL: dequant(gpu_q) diverges between backends\n");
+        return 1;
+    }
+
+    // ---- 4. full round-trip error on GPU -----------------------------------
+    // Normalize x to unit norm per 128-block and see that round-trip MSE is
+    // in the right ballpark (~10^-4 per coord; CPU baseline gets ~7e-5).
+    std::vector<float> x_unit = x;
+    for (int64_t b = 0; b < N_BLOCKS; ++b) {
+        double s = 0;
+        for (int i = 0; i < 128; ++i) s += (double)x_unit[b*128+i] * x_unit[b*128+i];
+        s = std::sqrt(s);
+        if (s > 0) for (int i = 0; i < 128; ++i) x_unit[b*128+i] /= (float)s;
+    }
+    auto qu_gpu = run_cpy_on_backend<uint8_t>(gpu, x_unit.data(), GGML_TYPE_F32, GGML_TYPE_TQ_MSE_4, n);
+    auto xh_gpu = run_cpy_on_backend<float>(gpu, (const float *)qu_gpu.data(), GGML_TYPE_TQ_MSE_4, GGML_TYPE_F32, n);
+    const float rt_mse = mean_sq_err(x_unit.data(), xh_gpu.data(), n);
+    printf("[test-turboquant-cuda] unit-norm GPU round-trip MSE: %.5f (CPU baseline ~7e-5)\n",
+           rt_mse);
+    if (!(rt_mse < 5e-3f)) {
+        printf("FAIL: round-trip MSE too high\n");
+        return 1;
+    }
+
+    printf("[test-turboquant-cuda] OK\n");
+
+    ggml_backend_free(gpu);
+    ggml_backend_free(cpu);
+    return 0;
+}
